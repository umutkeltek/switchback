# sb.env — live defaults for the `sb` CLI. Copy to ~/.config/switchback/sb.env
# and edit, or change these from the menu: `sb settings`. All values are optional;
# the CLI falls back to the defaults shown here.

# Default mode each tool runs in when you don't pass --mode.
export SB_DEFAULT_CODEX_MODE="tap"        # tap | relay | native | free
export SB_DEFAULT_CLAUDE_MODE="native"    # native | free
export SB_DEFAULT_ACCOUNT="default"       # a ChatGPT profile name (see `sb accounts`)

# Codex tap/native model + reasoning effort.
export SB_CODEX_MODEL="gpt-5.5"
export SB_CODEX_EFFORT="high"             # minimal | low | medium | high

# Gateway model used by opencode / pi (must exist in the gateway catalog;
# `openrouter` streams clean free output).
export SB_GW_MODEL="openrouter"
