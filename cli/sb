_pick_codex_mode() {
  printf '%s\n' \
    "tap"$'\t'"▸ tap      native request, observed real-time   · very low risk$(_mark tap $SB_DEFAULT_CODEX_MODE)" \
    "relay"$'\t'"▸ relay    Mode C — canonical routing/usage     · re-shaped$(_mark relay $SB_DEFAULT_CODEX_MODE)" \
