      *) print "unknown verify target: $1"; exit 1 ;;
    esac ;;
  usage)          sb_usage ;;
  traces)         sb_recent_traces ;;
  sessions)       sb_sessions "$@" ;;
  reload)         sb_reload; sb_status ;;

  codex)    _take_opts "$@"
            if [[ -n "$provider" ]]; then _run_codex_lane "$provider" "${REST[@]}"
            else _run_codex "${mode:-$SB_DEFAULT_CODEX_MODE}" "$account" "${REST[@]}"; fi ;;
  claude)   sb_claude "$@" ;;
  opencode) sb_opencode "$@" ;;
  pi)       sb_pi "$@" ;;

  # Surface the engine's own provider/vault/setup CLIs against the live config.
  lane)     sb_lane "$@" ;;
  provider) _switchback provider --config "$SB_CONFIG" "$@" ;;
  vault)    _switchback vault --config "$SB_CONFIG" "$@" ;;
  setup)
    case "${1:-}" in
      native|native-relay) _switchback setup "$@" --config "$SB_CONFIG" ;;
      *) _switchback setup "$@" ;;
    esac ;;

  login)    sub="${1:-codex}"; [[ "$sub" == "codex" ]] && shift
            _take_opts "$@"; sb_login "$account" ;;

  accounts)
    print "Codex accounts (ChatGPT profiles):"
    for a in ${(f)"$(_accounts_list)"}; do
      chome="$(_codex_home "$a")"
      n=$(find "${chome}/sessions" -name '*.jsonl' 2>/dev/null | wc -l | tr -d ' ')
