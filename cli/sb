if [[ -n "${ANTHROPIC_CUSTOM_HEADERS:-}" ]]; then
export ANTHROPIC_CUSTOM_HEADERS="${ANTHROPIC_CUSTOM_HEADERS}"$'\n'"${header}"
else
export ANTHROPIC_CUSTOM_HEADERS="$header"
fi
}

_exec_claude_provider_mode() {
  local label="$1" base_url="$2" token="$3" opus_model="$4" sonnet_model="$5"
  local haiku_model="$6" default_model="$7" effort="$8" compact_window="$9"
  local custom_name="${10}" custom_description="${11}"
  shift 11

local use_bare="${SB_CLAUDE_PROVIDER_BARE:-1}"
local use_mcp="${SB_CLAUDE_PROVIDER_MCP:-0}"
local mcp_spec="${SB_CLAUDE_PROVIDER_MCP_SERVERS:-gbrain}"
local use_skills="${SB_CLAUDE_PROVIDER_SKILLS:-0}"
local rich="${SB_CLAUDE_PROVIDER_RICH:-0}"
local -a pass_args=()
while (( $# )); do
case "$1" in
--mcp|--with-mcp) use_mcp=1; shift ;;
--mcp=*|--with-mcp=*) use_mcp=1; mcp_spec="${1#*=}"; shift ;;
--mcp-servers=*|--mcp-server=*) use_mcp=1; mcp_spec="${1#*=}"; shift ;;
--mcp-servers|--mcp-server) use_mcp=1; mcp_spec="${2:-}"; shift 2 ;;
--all-mcp|--mcp-all) use_mcp=1; mcp_spec="all"; shift ;;
--no-mcp) use_mcp=0; shift ;;
      --skills|--with-skills) use_skills=1; use_bare=0; shift ;;
      --no-skills) use_skills=0; shift ;;
      --rich) rich=1; use_bare=0; use_mcp=1; use_skills=1; shift ;;
      --full) rich=1; use_bare=0; use_mcp=1; use_skills=1; shift ;;
      --bare) use_bare=1; shift ;;
      --no-bare) use_bare=0; shift ;;
      *) pass_args+=("$1"); shift ;;
    esac
  done

  if [[ "$use_skills" == "1" ]]; then
    use_bare=0
  fi

  local chome
  chome="$(_claude_provider_home "$label")" || return 1

  unset ANTHROPIC_API_KEY
  unset CLAUDE_CODE_OAUTH_TOKEN CLAUDE_CODE_OAUTH_TOKEN_FILE_DESCRIPTOR CCR_OAUTH_TOKEN_FILE
  unset CLAUDE_CODE_API_KEY_FILE_DESCRIPTOR
  export CLAUDE_CONFIG_DIR="$chome"
  export ANTHROPIC_BASE_URL="$base_url"
  export ANTHROPIC_AUTH_TOKEN="$token"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$opus_model"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$sonnet_model"
  if [[ -n "$haiku_model" ]]; then
    export ANTHROPIC_DEFAULT_HAIKU_MODEL="$haiku_model"
  else
    unset ANTHROPIC_DEFAULT_HAIKU_MODEL
  fi
  export ANTHROPIC_CUSTOM_MODEL_OPTION="$default_model"
  export ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="$custom_name"
  export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="$custom_description"
  export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="${CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY:-1}"
  unset ANTHROPIC_MODEL CLAUDE_CODE_EFFORT_LEVEL

_claude_provider_seed_settings "$chome" "$default_model" "$effort" "$compact_window" "$opus_model" "$sonnet_model" "$haiku_model"
  if [[ "$rich" == "1" ]]; then
    _claude_provider_link_user_assets "$chome"
  elif [[ "$use_skills" == "1" ]]; then
    _claude_provider_unlink_user_assets "$chome" commands agents
    _claude_provider_link_user_assets "$chome" skills
  fi

  export ENABLE_TOOL_SEARCH="${ENABLE_TOOL_SEARCH:-true}"
  export API_TIMEOUT_MS="${API_TIMEOUT_MS:-3000000}"

 local -a provider_args=()
if [[ "$use_bare" == "1" ]]; then
provider_args+=(--bare)
 fi
local mcp_config=""
if [[ "$use_mcp" == "1" ]]; then
mcp_config="$(_claude_on_demand_mcp_config "$chome" "${mcp_spec:-gbrain}" 2>/dev/null || true)"
if [[ -n "$mcp_config" ]]; then
provider_args+=(--mcp-config "$mcp_config" --strict-mcp-config)
else
print -P "%F{yellow}warning:%f no MCP config found for '${mcp_spec:-gbrain}'" >&2
fi
fi
local setting_sources=""
if [[ "$use_skills" == "1" || "$rich" == "1" ]]; then
 setting_sources="user"
 fi
 provider_args+=(--setting-sources "$setting_sources")
 provider_args+=(--settings "${chome}/settings.json")
if [[ "$use_skills" == "1" ]]; then
local -a skill_dirs=()
skill_dirs=("${(@f)$(_claude_provider_add_skill_dirs "$chome")}")
    if (( ${#skill_dirs[@]} )); then
      provider_args+=(--add-dir "${skill_dirs[@]}")
    fi
  fi

  exec command "$NATIVE_CLAUDE" "${provider_args[@]}" "${pass_args[@]}"
}

