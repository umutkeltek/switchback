            f"{row.get('model_id','')[:46]:46} "
            f"{money(row.get('input_micros_per_mtok')):8} "
            f"{money(row.get('output_micros_per_mtok')):8} "
            f"{str(row.get('context_window') or '?')[:9]:9} "
            f"{short(flags, 52)}"
        )

def print_capabilities(rows):
    print("provider model ctx provider_ctx in out tool json seed reason arch")
    for row in rows:
