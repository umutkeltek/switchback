    src="${src_root}/${name}"
    dst="${chome}/${name}"
    [[ -e "$src" ]] || continue
    [[ -e "$dst" || -L "$dst" ]] && continue
    ln -s "$src" "$dst" 2>/dev/null || true
  done
}

_claude_provider_unlink_user_assets() {
  local chome="$1" src_root name src dst
  src_root="$(_claude_user_config_dir)"
  for name in "$@"; do
    src="${src_root}/${name}"
    dst="${chome}/${name}"
    if [[ -L "$dst" && "$(readlink "$dst" 2>/dev/null || true)" == "$src" ]]; then
      rm -f "$dst" 2>/dev/null || true
    fi
  done
}

_claude_provider_user_skill_mount() {
  local chome="$1" src_root src mount dst
  src_root="$(_claude_user_config_dir)"
  src="${src_root}/skills"
  [[ -d "$src" ]] || return 0

  mount="${chome}/switchback-user-skills"
  dst="${mount}/.claude/skills"
  mkdir -p "${mount}/.claude" || return 0

  if [[ -L "$dst" && "$(readlink "$dst" 2>/dev/null || true)" != "$src" ]]; then
    rm -f "$dst" 2>/dev/null || true
  fi
  if [[ ! -e "$dst" && ! -L "$dst" ]]; then
    ln -s "$src" "$dst" 2>/dev/null || return 0
  fi

  print -r -- "$mount"
}

_claude_provider_add_skill_dirs() {
  local chome="$1" user_mount
  local -a dirs=()

  user_mount="$(_claude_provider_user_skill_mount "$chome")"
  [[ -n "$user_mount" ]] && dirs+=("$user_mount")

  if [[ -d "${PWD}/.claude/skills" ]]; then
    dirs+=("$PWD")
  fi

  (( ${#dirs[@]} )) && print -r -- "${dirs[@]}"
}


_claude_provider_seed_settings() {
local chome="$1" default_model="$2" effort="$3" compact_window="$4" opus_model="$5" sonnet_model="$6" haiku_model="$7"
local helper="${SB_CLAUDE_API_KEY_HELPER:-/bin/sh -c 'printf %s \"\$ANTHROPIC_AUTH_TOKEN\"'}"
local settings="${chome}/settings.json" user_settings user_json tmp

mkdir -p "$chome"
[[ -f "$settings" ]] || print -r -- "{}" >| "$settings"
_have jq || return 0

user_settings="$(_claude_user_config_dir)/settings.json"
if [[ -f "$user_settings" ]]; then
user_json="$(jq -c '{
  permissions,
  autoMode,
  skipAutoPermissionPrompt,
  skipDangerousModePermissionPrompt,
  skipWorkflowUsageWarning
} | with_entries(select(.value != null))' "$user_settings" 2>/dev/null || print -r -- "{}")"
else
user_json="{}"
fi

tmp="$(mktemp)"
jq \
--arg model "$default_model" \
--arg effort "$effort" \
--arg compact "$compact_window" \
--arg opus "$opus_model" \
--arg sonnet "$sonnet_model" \
--arg haiku "$haiku_model" \
--argjson user "$user_json" \
--arg helper "$helper" '
def env_obj: if (.env | type) == "object" then .env else {} end;
def put_env_if_missing($key; $value):
  if $value != "" then
    (env_obj) as $env
    | .env = ($env + (if (($env[$key] // "") == "") then {($key): $value} else {} end))
  else . end;
(if type == "object" then . else {} end)
| if ($model != "" and ((.model // "") == "")) then .model = $model else . end
| if ($effort != "" and ((.effortLevel // "") == "")) then .effortLevel = $effort else . end
| if ($helper != "" and (((.apiKeyHelper // "") == "") or ((.apiKeyHelper // "") == "none"))) then .apiKeyHelper = $helper else . end
| put_env_if_missing("CLAUDE_CODE_AUTO_COMPACT_WINDOW"; $compact)
| put_env_if_missing("ANTHROPIC_DEFAULT_OPUS_MODEL"; $opus)
| put_env_if_missing("ANTHROPIC_DEFAULT_SONNET_MODEL"; $sonnet)
| put_env_if_missing("ANTHROPIC_DEFAULT_HAIKU_MODEL"; $haiku)
| reduce ["permissions", "autoMode", "skipAutoPermissionPrompt", "skipDangerousModePermissionPrompt", "skipWorkflowUsageWarning"][] as $key (.;
    if (.[$key] == null and $user[$key] != null) then .[$key] = $user[$key] else . end
  )
' "$settings" >| "$tmp" && mv "$tmp" "$settings" || {
rm -f "$tmp"
return 0
}
}

_append_anthropic_custom_header() {
