# Allow `SB_SOURCE_ONLY=1 source sb` to load functions for tests without dispatching.
if [[ -n "${SB_SOURCE_ONLY:-}" ]]; then return 0 2>/dev/null || exit 0; fi

cmd="${1:-menu}"; shift 2>/dev/null || true

case "$cmd" in
  menu|ui|tui|"") sb_menu ;;
