sb_login() {
  local account="${1:-default}" chome
  _codex_require_account_name "$account" || return 1
  chome="$(_codex_home "$account")"; mkdir -p "$chome"
  local exclusive=0
  if [[ "$SB_SESSION_MODE" == shared && "$account" == default ]]; then
    _shared_begin_exclusive_run "login:${account}" "$$" || return 1
    exclusive=1
  fi
  if [[ "$SB_SESSION_MODE" == shared ]]; then   # capture the live slot's owner before any change
    _seed_authreg
    [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp -f "${SB_MAIN_HOME}/auth.json" "$(_authreg_path "$(_shared_active)")" 2>/dev/null
  fi
  print -P "Logging in ChatGPT account %F{cyan}${account}%f (CODEX_HOME=${chome}). A browser will open."
  CODEX_HOME="$chome" command codex login
  local rc=$?
  if (( rc != 0 )); then
    (( exclusive )) && _shared_end_exclusive_run "$$"
    return $rc
  fi
  if [[ "$SB_SESSION_MODE" == shared ]]; then   # keep the registry in sync with the fresh credential
    _seed_authreg
    [[ -f "${chome}/auth.json" ]] && cp -f "${chome}/auth.json" "$(_authreg_path "$account")" 2>/dev/null
    [[ "$account" == default ]] && echo default > "$SB_ACTIVE_FILE"   # ~/.codex now holds default
  fi
  (( exclusive )) && _shared_end_exclusive_run "$$"
  print -P "%F{green}Done.%f  Run it:  sb codex --account ${account}"
}

# ─────────────── coding-plan provider lanes ───────────────
# A "lane" runs a coding agent (Codex/Claude Code) through a third-party provider's
# coding plan, observed. Generic: any provider is just a record of
# {anthropic_url, openai_url, key_env, model}. Two transports, picked per agent:
#   • Claude Code → a verbatim tap (server.taps): Claude speaks Anthropic Messages and
#     coding endpoints expose one, so the request is forwarded UNMODIFIED (plan-compliant).
#   • Codex → the engine (a provider + route, mode switchback_ingress): modern Codex speaks
#     only the Responses API while coding endpoints are Chat Completions, so the engine
#     translates Responses→Chat. A verbatim tap cannot bridge that.
# Reuses the engine's own `config set server.taps` and `provider add` (both idempotent).
# For pure engine-relay providers + the encrypted key vault, see `sb provider` / `sb vault`.

_lane_file() { echo "${SB_LANES}/$1.env"; }

# Built-in presets: name → "anthropic_url|openai_url|key_env|model|fast_model|wire_api".
# Anything not listed is fully flag-driven (still generic). Add presets here as they're verified.
_lane_preset() { case "$1" in
zai|z.ai|glm) echo "https://api.z.ai/api/anthropic|https://api.z.ai/api/coding/paas/v4|ZAI_API_KEY|glm-5.2|glm-4.5-air|chat" ;;
neuralwatt|nw) echo "|https://api.neuralwatt.com/v1|NEURALWATT_API_KEY|glm-5.2|glm-5.2-fast|chat" ;;
opencode-go|ocg) echo "|https://opencode.ai/zen/go/v1|OPENCODE_GO_API_KEY|glm-5.2|deepseek-v4-flash|chat" ;;
*) return 1 ;;
esac }

_lane_extra_models() { case "$1" in
neuralwatt|nw) print -r -- "glm-5.2-fast"$'\n'"glm-5.2-short"$'\n'"glm-5.2-short-fast"$'\n'"moonshotai/Kimi-K2.5"$'\n'"kimi-k2.5-fast"$'\n'"kimi-k2.6"$'\n'"kimi-k2.6-fast"$'\n'"kimi-k2.7-code"$'\n'"qwen3.6-35b"$'\n'"qwen3.6-35b-fast"$'\n'"qwen3.5-397b"$'\n'"qwen3.5-397b-fast" ;;
opencode-go|ocg) print -r -- "glm-5.1"$'\n'"glm-5"$'\n'"kimi-k2.7-code"$'\n'"kimi-k2.6"$'\n'"kimi-k2.5"$'\n'"deepseek-v4-pro"$'\n'"deepseek-v4-flash"$'\n'"mimo-v2.5"$'\n'"mimo-v2.5-pro" ;;
*) return 1 ;;
esac }

# Resolve a key by env-var name: live env (sb already sourced sb.env) wins.
_lane_keyval() { local n="$1"; print -r -- "${(P)n:-}"; }
_lane_secret_status() {
  local name="$1" key_env="$2" providers
  local provider_id="${name}-coding"
  [[ -n "$key_env" && -n "$(_lane_keyval "$key_env")" ]] && { print -r -- "env"; return 0; }
  providers="$(_switchback config get providers --json --config "$SB_CONFIG" 2>/dev/null)" || providers="[]"
  PROVIDERS="$providers" PID="$provider_id" python3 - <<'PY'
import json, os

try:
    providers = json.loads(os.environ.get("PROVIDERS") or "[]")
except Exception:
    providers = []
pid = os.environ["PID"]
for provider in providers:
    if not isinstance(provider, dict) or provider.get("id") != pid:
        continue
    for account in provider.get("accounts") or []:
        auth = (account or {}).get("auth") or {}
        vault = auth.get("vault")
        if vault:
            print(f"vault:{vault}")
            raise SystemExit(0)
print("unset")
PY
}

_opencode_go_key_from_auth() {
  local auth="${HOME}/.local/share/opencode/auth.json"
  [[ -f "$auth" ]] || return 1
  jq -r '."opencode-go".key // empty' "$auth" 2>/dev/null | tr -d '[:space:]'
}

# Idempotent CLAUDE tap upsert (verbatim Anthropic) via the engine's canonical config
# writer. args: <name> <anthropic_url> → echoes "<anth_port> changed|same".
# Only touches config when the tap is missing/different, so a generator-owned config
# (tap already present) is left byte-for-byte intact.
_lane_sync_claude_tap() {
  local name="$1" au="$2" cur tmp out
  cur="$(_switchback config get server.taps --json --config "$SB_CONFIG" 2>/dev/null)"; [[ -n "$cur" ]] || cur="[]"
  tmp="$(mktemp)"
  out="$(CUR="$cur" NAME="$name" AU="$au" TMP="$tmp" python3 - <<'PY'
import json, os
cur = json.loads(os.environ.get("CUR") or "[]")
if not isinstance(cur, list): cur = []
name, au = os.environ["NAME"], os.environ["AU"]
taps = {t.get("id"): dict(t) for t in cur if t.get("id")}
order = [t.get("id") for t in cur if t.get("id")]
def port(b):
    try: return int(str(b).rsplit(":", 1)[1])
    except Exception: return 0
used = [port(t.get("bind")) for t in cur if t.get("bind")]
tid = f"{name}-claude-tap"
ap = port(taps[tid]["bind"]) if tid in taps else None
if au and not ap: ap = max(used + [18771]) + 1
changed = False
if au and ap:
    new = {"id": tid, "bind": f"127.0.0.1:{ap}", "upstream": au, "capture_bodies": True}
    if taps.get(tid) != new: changed = True
    if tid not in taps: order.append(tid)
    taps[tid] = new
open(os.environ["TMP"], "w").write(json.dumps([taps[i] for i in order if i in taps]))
print(f"{ap or 0} {'changed' if changed else 'same'}")
PY
)"
  local ap ch; ap="${out%% *}"; ch="$(print -r -- "$out" | awk '{print $2}')"
  if [[ "$ch" == changed ]]; then
    _switchback config set server.taps "$(cat "$tmp")" --config "$SB_CONFIG" >/dev/null || { rm -f "$tmp"; return 1; }
  fi
  rm -f "$tmp"
  print -r -- "$ap $ch"
}

# Idempotent CODEX engine provider+route. Modern Codex speaks only the Responses API
# while coding-plan endpoints are Chat Completions, so Codex must go through the engine
# (which translates). args: <name> <openai_url> <key_env> <model> → echoes "<route> changed|same".
# Skips the write when a provider with the same id+base_url already exists (keeps a
# generator-owned config intact); otherwise uses `provider add --force`.
_lane_ensure_provider() {
local name="$1" ou="$2" ke="$3" model="$4"
local pid="${name}-coding" route="${name}/${model}"
local target="${pid}/${model}"
local providers routes have
providers="$(_switchback config get providers --json --config "$SB_CONFIG" 2>/dev/null)" || providers="[]"
routes="$(_switchback config get routes --json --config "$SB_CONFIG" 2>/dev/null)" || routes="[]"
have="$(PROVIDERS="$providers" ROUTES="$routes" PID="$pid" OU="$ou" ROUTE="$route" TARGET="$target" python3 - <<'PY'
import json, os

def load(name, default):
    try:
        return json.loads(os.environ.get(name) or default)
    except Exception:
        return json.loads(default)

providers = load("PROVIDERS", "[]")
routes = load("ROUTES", "[]")
pid = os.environ["PID"]
ou = os.environ["OU"]
route = os.environ["ROUTE"]
target = os.environ["TARGET"]
provider_ok = any(p.get("id") == pid and p.get("base_url") == ou for p in providers if isinstance(p, dict))
route_ok = any(
    isinstance(r, dict)
    and ((r.get("match") or {}).get("model") == route)
    and target in (r.get("targets") or [])
    for r in routes
)
print("yes" if provider_ok and route_ok else "no")
PY
)"
if [[ "$have" == yes ]]; then print -r -- "$route same"; return 0; fi
_switchback provider add openai --id "$pid" --base-url "$ou" --api-key-env "$ke" \
--model "$model" --route "$route" --force --config "$SB_CONFIG" >/dev/null 2>&1 || { print -r -- "$route fail"; return 1; }
print -r -- "$route changed"
}

_lane_add() {
  local name="" au="" ou="" ke="" model="" fast="" wire="chat" preset="" wire_set=0
  local -a rest=()
  while (( $# )); do case "$1" in
    --preset) preset="${2:-}"; shift 2 ;;
    --anthropic-url) au="${2:-}"; shift 2 ;;
    --openai-url) ou="${2:-}"; shift 2 ;;
    --key-env) ke="${2:-}"; shift 2 ;;
    --model) model="${2:-}"; shift 2 ;;
    --fast-model) fast="${2:-}"; shift 2 ;;
    --wire-api) wire="${2:-}"; wire_set=1; shift 2 ;;
    --*) print "unknown flag: $1"; return 1 ;;
    *) rest+=("$1"); shift ;;
  esac; done
  name="${rest[1]:-}"
  [[ -n "$name" ]] || { print "usage: sb lane add <name> [--preset P | --anthropic-url U --openai-url U --key-env VAR --model M [--fast-model F] [--wire-api chat|responses]]"; return 1; }
  _valid_profile_name "$name" || { print "invalid lane name: $name"; return 1; }
  local p; p="$(_lane_preset "${preset:-$name}")" || p=""
  if [[ -n "$p" ]]; then
    local pa po pk pm pf pw; IFS='|' read -r pa po pk pm pf pw <<< "$p"
    : "${au:=$pa}"; : "${ou:=$po}"; : "${ke:=$pk}"; : "${model:=$pm}"; : "${fast:=$pf}"
    (( wire_set )) || wire="$pw"
  fi
  [[ -n "$ke" ]] || { print "missing --key-env (the env var holding the provider key)"; return 1; }
  [[ -n "$au$ou" ]] || { print "need --anthropic-url and/or --openai-url"; return 1; }
  [[ -n "$model" ]] || { print "missing --model"; return 1; }
  local ap="" route="" need_reload=0 out="" ch=""
  # Claude side → verbatim tap (Claude speaks Anthropic; z.ai coding speaks Anthropic).
  if [[ -n "$au" ]]; then
    out="$(_lane_sync_claude_tap "$name" "$au")" || { print "tap sync failed"; return 1; }
    ap="${out%% *}"; ch="$(print -r -- "$out" | awk '{print $2}')"
    [[ "$ch" == changed ]] && need_reload=1
  fi
  # Codex side → engine provider+route (Codex is Responses-only; engine translates to Chat).
  if [[ -n "$ou" ]]; then
    out="$(_lane_ensure_provider "$name" "$ou" "$ke" "$model")" || { print "provider add failed"; return 1; }
    route="${out%% *}"; ch="$(print -r -- "$out" | awk '{print $2}')"
    [[ "$ch" == changed ]] && need_reload=1
    local extra extra_out extra_ch
    for extra in ${(f)"$(_lane_extra_models "${preset:-$name}" 2>/dev/null || true)"}; do
      [[ -n "$extra" && "$extra" != "$model" ]] || continue
      extra_out="$(_lane_ensure_provider "$name" "$ou" "$ke" "$extra")" || { print "provider add failed for ${extra}"; return 1; }
      extra_ch="$(print -r -- "$extra_out" | awk '{print $2}')"
      [[ "$extra_ch" == changed ]] && need_reload=1
    done
  fi
  mkdir -p "$SB_LANES"
  local f; f="$(_lane_file "$name")"
  cat > "$f" <<EOF
SB_LANE_NAME="${name}"
SB_LANE_ANTHROPIC_URL="${au}"
SB_LANE_OPENAI_URL="${ou}"
SB_LANE_KEY_ENV="${ke}"
SB_LANE_MODEL="${model}"
SB_LANE_FAST_MODEL="${fast}"
SB_LANE_WIRE_API="${wire}"
SB_LANE_ANTHROPIC_TAP="${ap}"
SB_LANE_ROUTE="${route}"
EOF
  chmod 600 "$f"
  print -P "%F{green}lane '${name}' saved%f → ${f}"
  [[ -n "$au" ]] && print "  claude → tap :${ap} (verbatim) → ${au}"
  [[ -n "$ou" ]] && print "  codex  → engine route ${route} → ${ou} (Responses→Chat)"
  print "  model: ${model}${fast:+   fast: ${fast}}   key-env: ${ke}"
  if (( need_reload )); then
    print -P "  config changed → %F{yellow}not reloaded%f"
    print "  Reload when active sessions are safe: sb reload"
  fi
  [[ -z "$(_lane_keyval "$ke")" ]] && print -P "  %F{yellow}key not set.%f  →  sb lane key ${name}"
  print "Run it:  sb codex --provider ${name}   ·   sb claude --provider ${name}"
}

_lane_print_gateway_routes() {
 local routes
 routes="$(_switchback config get routes --json --config "$SB_CONFIG" 2>/dev/null)" || return 0
 [[ -n "$routes" ]] || return 0
 print ""
 print -P "%F{cyan}Built-in gateway routes%f"
 ROUTES="$routes" python3 - <<'PY'
import json, os

try:
    routes = json.loads(os.environ.get("ROUTES") or "[]")
except Exception:
    routes = []

wanted = {
    "scout/code": "free coding mode; OpenRouter free first, then NVIDIA/DeepSeek/z.ai fallbacks",
    "scout/chat": "free chat/batch mode; OpenRouter free first, then NVIDIA/DeepSeek/z.ai fallbacks",
    "local/mac-code": "LM Studio code route on 127.0.0.1:1234",
    "local/mac-fast": "LM Studio fast route on 127.0.0.1:1234",
    "zai/glm-5.2": "z.ai coding-plan route used by codex-zai",
    "*": "generic gateway fallback ladder",
}

def model_of(route):
    return str((route.get("match") or {}).get("model") or "")

def label_target(target):
    target = str(target)
    if target.startswith("openrouter/") and target.endswith(":free"):
        return f"{target} [openrouter-free]"
    if target.startswith("openrouter/"):
        return f"{target} [openrouter]"
    if target.startswith("nvidia/"):
        return f"{target} [nvidia-build]"
    if target.startswith("deepseek/"):
        return f"{target} [deepseek]"
    if target.startswith("zai") or target.startswith("zai-coding/"):
        return f"{target} [z.ai]"
    if target.startswith("mac/") or target.startswith("fedora/"):
        return f"{target} [local]"
    return target

for route in routes:
    model = model_of(route)
    if model not in wanted:
        continue
    targets = [label_target(t) for t in (route.get("targets") or [])]
    if not targets:
        continue
    print(f"  {model:<16} {wanted[model]}")
    for target in targets[:8]:
        print(f"    - {target}")
    if len(targets) > 8:
        print(f"    - ... {len(targets) - 8} more")
PY
 print ""
 print "Run built-ins through the same front door:"
 print " codex free:   sb codex --mode free"
 print " claude free:  sb claude --mode free"
 print " local model:  sb codex-lmstudio | sb claude-lmstudio"
}

