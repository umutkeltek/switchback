# Drop a lane's entry from one config array via the engine's canonical writer (atomic +
# validated; a bad write leaves config intact). args: <config-path> <lane> <kind>.
# Returns 0 only if it actually changed the config.
_lane_cfg_drop() {
  local path="$1" name="$2" kind="$3" cur tmp
  cur="$(_switchback config get "$path" --json --config "$SB_CONFIG" 2>/dev/null)"; [[ -n "$cur" ]] || return 1
  tmp="$(mktemp)"
  if CUR="$cur" NAME="$name" KIND="$kind" TMP="$tmp" python3 - <<'PY'
import json, os, sys
cur = json.loads(os.environ.get("CUR") or "[]")
if not isinstance(cur, list): sys.exit(1)
name, kind = os.environ["NAME"], os.environ["KIND"]
def keep(e):
    if kind == "tap":      return e.get("id") != f"{name}-claude-tap"
    if kind == "provider": return e.get("id") != f"{name}-coding"
    if kind == "route":    return not any(str(t).startswith(f"{name}-coding/") for t in (e.get("targets") or []))
    return True
out = [e for e in cur if keep(e)]
open(os.environ["TMP"], "w").write(json.dumps(out))
sys.exit(0 if len(out) != len(cur) else 1)
PY
  then _switchback config set "$path" "$(cat "$tmp")" --config "$SB_CONFIG" >/dev/null; rm -f "$tmp"; return 0
  else rm -f "$tmp"; return 1; fi
}

_lane_rm() {
  local name="${1:-}"; [[ -n "$name" ]] || { print "usage: sb lane rm <name>"; return 1; }
  local f; f="$(_lane_file "$name")"
  [[ -f "$f" ]] || { print "no such lane: $name"; return 1; }
  rm -f "$f"
  local changed=0
  _lane_cfg_drop server.taps "$name" tap      && changed=1   # claude verbatim tap
  _lane_cfg_drop providers   "$name" provider && changed=1   # codex engine provider
  _lane_cfg_drop routes      "$name" route    && changed=1   # codex engine route
  if (( changed )); then
    print -P "%F{green}lane '${name}' removed%f (record + engine tap/provider/route). reloading…"; sb_reload
  else
    print -P "%F{green}lane '${name}' removed%f (record only; no engine entries to detach)"
  fi
}

_lane_key() {
  local name="" stdin=0
  while (( $# )); do case "$1" in --stdin) stdin=1; shift ;; --*) print "unknown flag: $1"; return 1 ;; *) name="$1"; shift ;; esac; done
  [[ -n "$name" ]] || { print "usage: sb lane key <name> [--stdin]"; return 1; }
  local f; f="$(_lane_file "$name")"; [[ -f "$f" ]] || { print "no such lane: $name (add it: sb lane add $name)"; return 1; }
  local ke; ke="$(grep '^SB_LANE_KEY_ENV=' "$f" | cut -d= -f2- | tr -d '"')"
  [[ -n "$ke" ]] || { print "lane '$name' has no key-env"; return 1; }
  local key=""
  if (( stdin )); then key="$(cat | tr -d '[:space:]')"
  elif _have pbpaste; then key="$(pbpaste 2>/dev/null | tr -d '[:space:]')"; fi
  if [[ -z "$key" || "${#key}" -lt 8 ]]; then
    print -n "Paste ${ke} (hidden): "; read -rs key; print ""; key="${key//[[:space:]]/}"
  fi
  [[ -n "$key" && "${#key}" -ge 8 ]] || { print "no usable key provided"; return 1; }
  _set_env "$ke" "$key"
  print -P "%F{green}${ke} set (${#key} chars)%f → ${SB_ENV}"
  print "Run it:  sb codex --provider ${name}   ·   sb claude --provider ${name}"
}

sb_lane() {
  case "${1:-list}" in
    add)        shift; _lane_add "$@" ;;
    list|ls|"") _lane_list ;;
    show|get)   shift; _lane_show "$@" ;;
    rm|remove)  shift; _lane_rm "$@" ;;
    key)        shift; _lane_key "$@" ;;
    doctor)     shift; _switchback lane doctor --config "$SB_CONFIG" "$@" ;;
    presets)    print "presets: zai (z.ai GLM Coding Plan). Others: use the flags."; ;;
    -h|--help|help)
      cat <<'EOF'
sb lane — run a coding agent through a third-party provider's native endpoint, observed.

  sb lane add zai                          add a preset lane (z.ai GLM Coding Plan)
  sb lane add NAME --anthropic-url U --openai-url U --key-env VAR --model M [--fast-model F] [--wire-api chat|responses]
  sb lane list                             configured lanes + tap status + key presence
  sb lane key NAME [--stdin]               set the provider key (clipboard · stdin · hidden prompt) → sb.env
  sb lane show NAME                        print the lane record
  sb lane rm NAME                          remove the lane + its taps

Then run it:
  sb codex  --provider NAME [args]         Codex via the engine (Responses→Chat), observed
  sb claude --provider NAME [args]         Claude Code via the verbatim Anthropic tap, observed

Claude runs verbatim through a tap (plan-compliant); Codex runs through the engine
because modern Codex speaks only the Responses API while coding endpoints are Chat
Completions. For pure engine-relay providers + the encrypted key vault, see
`sb provider` and `sb vault`.
EOF
      ;;
    *) print "unknown: sb lane $1 (try: sb lane help)"; return 1 ;;
  esac
}

_run_codex_lane() {
  local name="$1"; shift
  source "$(_lane_file "$name")" 2>/dev/null || { print -P "%F{red}no such lane:%f $name  (add it: sb lane add $name)"; return 1; }
  [[ -n "${SB_LANE_ROUTE:-}" ]] || { print -P "%F{red}lane '$name' has no Codex route%f (add it with --openai-url)"; return 1; }
  # Codex (Responses) → the Switchback engine → the lane's coding provider (Responses→Chat
  # translation). The engine holds the provider key (env or vault); Codex auths to the
  # engine with a local scout token. The engine must be up.
  _up || print -P "%F{yellow}warning:%f engine :18765 down — sb reload%f" >&2
  export SWITCHBACK_SCOUT_API_KEY="${SWITCHBACK_SCOUT_API_KEY:-scout-local}"
  local eng="${GATEWAY%/}/v1"
  print -P "%F{8}codex → ${name} lane · engine ${eng} · route ${SB_LANE_ROUTE} · observed%f" >&2
  exec "$NATIVE_CODEX" \
    -c "model_provider=\"sblane-${name}\"" \
    -c "model=\"${SB_LANE_ROUTE}\"" \
    -c "model_providers.sblane-${name}={name=\"${name} lane\", base_url=\"${eng}\", wire_api=\"responses\", env_key=\"SWITCHBACK_SCOUT_API_KEY\", requires_openai_auth=false}" \
    "$@"
}

_run_claude_lane() {
  local name="$1"; shift
  source "$(_lane_file "$name")" 2>/dev/null || { print -P "%F{red}no such lane:%f $name  (add it: sb lane add $name)"; return 1; }
  [[ -n "${SB_LANE_ANTHROPIC_TAP:-}" ]] || { print -P "%F{red}lane '$name' has no Claude (Anthropic) endpoint%f"; return 1; }
  local kv; kv="$(_lane_keyval "$SB_LANE_KEY_ENV")"
  [[ -n "$kv" ]] || { print -P "%F{yellow}key not set:%f  sb lane key $name"; return 1; }
  _listening "$SB_LANE_ANTHROPIC_TAP" || print -P "%F{yellow}warning:%f claude tap :${SB_LANE_ANTHROPIC_TAP} not listening — sb reload" >&2
  print -P "%F{8}claude → ${name} lane · tap :${SB_LANE_ANTHROPIC_TAP} · ${SB_LANE_MODEL} · observed%f" >&2
  export ANTHROPIC_BASE_URL="http://127.0.0.1:${SB_LANE_ANTHROPIC_TAP}"
  export ANTHROPIC_AUTH_TOKEN="$kv"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$SB_LANE_MODEL"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$SB_LANE_MODEL"
  [[ -n "${SB_LANE_FAST_MODEL:-}" ]] && export ANTHROPIC_DEFAULT_HAIKU_MODEL="$SB_LANE_FAST_MODEL"
  export API_TIMEOUT_MS="${API_TIMEOUT_MS:-3000000}"
  exec command "$NATIVE_CLAUDE" "$@"
}

