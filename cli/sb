#!/bin/zsh
# sb — Switchback control. One front door for every AI tool, observed through
# Switchback. Run `sb` (no args) for the interactive menu (arrows ↑↓ · Enter ·
# Esc), or use subcommands directly. "Smart default + quick switch": each tool
# has a default mode you can run instantly or override per run.
#
#   Relay (LaunchAgent ai.switchback.scout) serves ~/.config/switchback/switchback.yaml
#   on :18765, with transparent taps on :18770 (claude) / :18771 (codex).
#   Live settings + defaults live in ~/.config/switchback/sb.env.
set -uo pipefail

SB_CONFIG="${HOME}/.config/switchback/switchback.yaml"
SB_ENV="${HOME}/.config/switchback/sb.env"
SB_STATE="${HOME}/.local/state/switchback"
CODEX_PROFILES="${CODEX_PROFILES:-${HOME}/.config/switchback/codex}"
CLAUDE_PROFILES="${CLAUDE_PROFILES:-${HOME}/.config/switchback/claude}"
SB_LANES="${SB_LANES:-${HOME}/.config/switchback/lanes}"   # coding-plan provider lanes (claude=verbatim tap, codex=engine relay)
GATEWAY="${SB_GATEWAY:-http://127.0.0.1:18765}"
SB_LAUNCH_LABEL="${SB_LAUNCH_LABEL:-ai.switchback.scout}"
PLIST="${SB_PLIST:-${HOME}/Library/LaunchAgents/${SB_LAUNCH_LABEL}.plist}"
FZF="$(command -v fzf || true)"

# Shared-session-mode plumbing (overridable for tests). In SHARED mode all accounts
# use the one ~/.codex pool; sb swaps ~/.codex/auth.json to the chosen account's
# credential (kept in a registry, with backups) so token refresh stays intact.
SB_MAIN_HOME="${SB_MAIN_HOME:-${HOME}/.codex}"
SB_AUTHREG="${SB_AUTHREG:-${HOME}/.config/switchback/codex-auth}"
SB_ACTIVE_FILE="${SB_AUTHREG}/.active"

# mode → command (codex). CODEX_HOME is set per account before exec.
TAP_WRAPPER="${HOME}/.local/bin/codex-switchback-tap"
RELAY_WRAPPER="${HOME}/.local/bin/codex-switchback-traced"
FREE_WRAPPER="${HOME}/.local/bin/codex-switchback-scout"
# Real binaries auto-detected from PATH (override with SB_NATIVE_CODEX / SB_NATIVE_CLAUDE).
NATIVE_CODEX="${SB_NATIVE_CODEX:-$(command -v codex 2>/dev/null || echo ${HOME}/.bun/bin/codex)}"
NATIVE_CLAUDE="${SB_NATIVE_CLAUDE:-$(command -v claude 2>/dev/null || echo ${HOME}/.local/bin/claude)}"
FREE_CLAUDE="${HOME}/.local/bin/claude-switchback-scout"

# Defaults (overridable via sb.env / Settings).
[ -f "$SB_ENV" ] && source "$SB_ENV"
SB_DEFAULT_CODEX_MODE="${SB_DEFAULT_CODEX_MODE:-tap}"
SB_DEFAULT_CLAUDE_MODE="${SB_DEFAULT_CLAUDE_MODE:-native}"
SB_DEFAULT_ACCOUNT="${SB_DEFAULT_ACCOUNT:-default}"
SB_DEFAULT_CLAUDE_ACCOUNT="${SB_DEFAULT_CLAUDE_ACCOUNT:-$SB_DEFAULT_ACCOUNT}"
SB_CODEX_MODEL="${SB_CODEX_MODEL:-gpt-5.5}"
SB_CODEX_EFFORT="${SB_CODEX_EFFORT:-xhigh}"
SB_GW_MODEL="${SB_GW_MODEL:-openrouter}"
# Default 'shared' = how native Codex already works: one ~/.codex pool, swap the
# credential per account. 'separated' is the opt-in isolation mode (own CODEX_HOME).
SB_SESSION_MODE="${SB_SESSION_MODE:-shared}"      # shared | separated

_up()        { curl -s -m 2 "${GATEWAY}/health" >/dev/null 2>&1; }
_listening() { /usr/sbin/lsof -nP -iTCP:"$1" -sTCP:LISTEN -t >/dev/null 2>&1; }
_have()      { command -v "$1" >/dev/null 2>&1; }
_pause()     { print -n "\n  (Enter to continue) "; read -r _; }
_codex_home(){ [[ "$1" == "default" ]] && echo "${HOME}/.codex" || echo "${CODEX_PROFILES}/$1"; }
_accounts_list() { { echo default; ls "${CODEX_PROFILES}" 2>/dev/null; } | awk 'NF'; }
_claude_home(){ [[ "$1" == "default" ]] && echo "${HOME}/.claude" || echo "${CLAUDE_PROFILES}/$1"; }
_claude_accounts_list() { { echo default; ls "${CLAUDE_PROFILES}" 2>/dev/null; } | awk 'NF'; }
_switchback() {
  if ! command -v switchback >/dev/null 2>&1; then
    print -P "%F{red}switchback binary not found on PATH%f" >&2
    return 127
  fi
  command switchback "$@"
}
_native_status_json() { _switchback --json native status --config "$SB_CONFIG" 2>/dev/null; }
_native_profiles_json() { _switchback --json native profiles list --config "$SB_CONFIG" 2>/dev/null; }

# Pull --account/--mode/--sessions/--provider out of args → sets `account`, `mode`,
# `sessmode`, `provider`, REST.
_take_opts() {
  account="${SB_OPT_DEFAULT_ACCOUNT:-$SB_DEFAULT_ACCOUNT}"; mode=""; sessmode=""; provider=""; local -a rest=()
  while (( $# )); do
    case "$1" in
      --account) account="${2:-default}"; shift 2 ;;
      --account=*) account="${1#--account=}"; shift ;;
      --mode) mode="${2:-}"; shift 2 ;;
      --mode=*) mode="${1#--mode=}"; shift ;;
      --sessions) sessmode="${2:-}"; shift 2 ;;
      --sessions=*) sessmode="${1#--sessions=}"; shift ;;
      --provider) provider="${2:-}"; shift 2 ;;
      --provider=*) provider="${1#--provider=}"; shift ;;
      *) rest+=("$1"); shift ;;
    esac
  done
  REST=("${rest[@]}")
}

# ── shared-session credential registry (refresh-safe auth.json swap) ──────────
_authreg_path() { echo "${SB_AUTHREG}/$1.json"; }
_shared_active() { cat "$SB_ACTIVE_FILE" 2>/dev/null || echo default; }

# Seed the registry once from live homes (copy, never move — non-destructive).
_seed_authreg() {
  mkdir -p "${SB_AUTHREG}/backups" || return 1
  [[ -f "$(_authreg_path default)" ]] || { [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp "${SB_MAIN_HOME}/auth.json" "$(_authreg_path default)"; }
  local a
  for a in ${(f)"$(ls "$CODEX_PROFILES" 2>/dev/null)"}; do
    [[ -f "$(_authreg_path "$a")" ]] || { [[ -f "${CODEX_PROFILES}/$a/auth.json" ]] && cp "${CODEX_PROFILES}/$a/auth.json" "$(_authreg_path "$a")"; }
  done
  [[ -f "$SB_ACTIVE_FILE" ]] || echo default > "$SB_ACTIVE_FILE"
}

_backup_main_auth() {
  [[ -f "${SB_MAIN_HOME}/auth.json" ]] || return 0
  local ts; ts="$(date +%Y%m%d-%H%M%S)"
  cp "${SB_MAIN_HOME}/auth.json" "${SB_AUTHREG}/backups/auth.$(_shared_active).${ts}.json" 2>/dev/null
  # prune to the newest 15 — array glob (never falls back to `ls` of the cwd)
  local -a bk; bk=("${SB_AUTHREG}/backups/"*.json(.Nom))   # om = newest first
  if (( ${#bk} > 15 )); then local f; for f in "${(@)bk[16,-1]}"; do rm -f "$f" 2>/dev/null; done; fi
}

# Make ~/.codex/auth.json hold account $1's credential, capturing any refresh of
# the previously-active account first. Returns 1 if $1 has no stored credential.
_activate_shared() {
  local want="$1"; _seed_authreg || return 1
  local reg; reg="$(_authreg_path "$want")"
  if [[ ! -f "$reg" ]]; then
    print -P "%F{yellow}No stored credential for '${want}'.%f  Log in:  sb login codex --account ${want}" >&2; return 1
  fi
  local cur; cur="$(_shared_active)"
  # persist any token refresh from the currently-live auth back to its slot
  [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp -f "${SB_MAIN_HOME}/auth.json" "$(_authreg_path "$cur")" 2>/dev/null
  if [[ "$want" != "$cur" || ! -f "${SB_MAIN_HOME}/auth.json" ]]; then
    _backup_main_auth
    cp -f "$reg" "${SB_MAIN_HOME}/auth.json" || { print -P "%F{red}auth swap failed%f" >&2; return 1; }
  fi
  echo "$want" > "$SB_ACTIVE_FILE"
}

# After a shared-mode session: persist refresh back to the account's registry slot.
_saveback_shared() { [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp -f "${SB_MAIN_HOME}/auth.json" "$(_authreg_path "$1")" 2>/dev/null; }

_set_env() {  # persist export KEY="VALUE" into sb.env
  local key="$1" val="$2"; mkdir -p "${SB_ENV:h}"; touch "$SB_ENV"
  if grep -q "^export ${key}=" "$SB_ENV" 2>/dev/null; then
    local tmp; tmp="$(mktemp)"; grep -v "^export ${key}=" "$SB_ENV" > "$tmp"; mv "$tmp" "$SB_ENV"
  fi
  echo "export ${key}=\"${val}\"" >> "$SB_ENV"
}

# fzf menu: stdin "key<TAB>label" → prints chosen key (empty on Esc).
_menu() {
  local prompt="${1:-› }" header="${2:-}"
  if [[ -n "$FZF" ]]; then
    "$FZF" --ansi --reverse --height='~70%' --prompt="$prompt" \
           ${header:+--header="$header"} --delimiter=$'\t' --with-nth=2.. --no-multi --no-info 2>/dev/null | cut -f1
  else
    local -a keys labels; local k l
    while IFS=$'\t' read -r k l; do keys+=("$k"); labels+=("$l"); done
    print -ru2 -- "$header"; local i=1
    for l in "${labels[@]}"; do print -ru2 -- "  $i) $l"; ((i++)); done
    print -nu2 -- "$prompt"; local n; read -r n; [[ "$n" == <-> ]] && echo "${keys[$n]}"
  fi
}

_mark() { [[ "$1" == "$2" ]] && echo "  ◀ default"; }  # _mark <value> <default>

# ─────────────────────────── launch ───────────────────────────

_codex_wrapper() { case "$1" in
  tap) echo "$TAP_WRAPPER" ;; relay) echo "$RELAY_WRAPPER" ;;
  free) echo "$FREE_WRAPPER" ;; native) echo "$NATIVE_CODEX" ;; *) return 1 ;;
esac }

_run_codex() {  # _run_codex <mode> <account> [args...]
  local m="$1" acct="$2"; shift 2
  local wrapper; wrapper="$(_codex_wrapper "$m")" || { print "unknown codex mode: $m"; return 1; }
  local sm="${sessmode:-$SB_SESSION_MODE}"

  if [[ "$sm" == shared ]]; then
    # All accounts share the ~/.codex session pool; swap the credential in.
    _activate_shared "$acct" || return 1
    [[ "$m" != native ]] && { _up || print -P "%F{yellow}warning:%f relay :18765 down — 'sb reload'" >&2; }
    print -P "%F{8}(shared sessions · ~/.codex pool · account: ${acct})%f" >&2
    # NOT exec — we must save the refreshed token back afterwards.
    CODEX_HOME="$SB_MAIN_HOME" "$wrapper" "$@"
    local rc=$?
    _saveback_shared "$acct"
    return $rc
  fi

  # separated: each account is its own CODEX_HOME (own auth + own sessions).
  local chome; chome="$(_codex_home "$acct")"
  if [[ "$m" == tap || "$m" == native ]] && [[ ! -f "${chome}/auth.json" ]]; then
    print -P "%F{yellow}Account '${acct}' isn't logged in.%f  →  sb login codex --account ${acct}"; return 1
  fi
  [[ "$m" != native ]] && { _up || print -P "%F{yellow}warning:%f relay :18765 down — 'sb reload'" >&2; }
  CODEX_HOME="$chome" exec "$wrapper" "$@"
}

_valid_profile_name() {
  local name="$1"
  [[ -n "$name" ]] || return 1
  [[ "$name" != "." && "$name" != ".." ]] || return 1
  [[ "$name" != *"/"* && "$name" != *":"* ]] || return 1
  [[ "$name" =~ '^[A-Za-z0-9][A-Za-z0-9._-]*$' ]]
}

_claude_history_mode() { [[ "$1" == "default" ]] && echo native || echo separate; }

_claude_latest_transcript_for_account() {
  local acct="$1" chome; chome="$(_claude_home "$acct")"
  local -a files
  files=("${chome}/projects"/**/*.jsonl(.Nom))
  (( ${#files} )) && print -r -- "${files[1]}"
}

_claude_latest_transcript() {
  local best_acct="" best_transcript="" acct transcript_path
  for acct in ${(f)"$(_claude_accounts_list)"}; do
    _valid_profile_name "$acct" || continue
    transcript_path="$(_claude_latest_transcript_for_account "$acct")"
    [[ -n "$transcript_path" ]] || continue
    if [[ -z "$best_transcript" || "$transcript_path" -nt "$best_transcript" ]]; then
      best_acct="$acct"
      best_transcript="$transcript_path"
    fi
  done
  [[ -n "$best_transcript" ]] && print -r -- "${best_acct}"$'\t'"${best_transcript}"
}

sb_watch_claude() {
  local acct="" transcript_path="" row="" rest=()
  while (( $# )); do
    case "$1" in
      --account) acct="${2:-}"; shift 2 ;;
      --account=*) acct="${1#--account=}"; shift ;;
      -h|--help)
        print "usage: sb watch claude [--account NAME]"
        return 0 ;;
      *) rest+=("$1"); shift ;;
    esac
  done
  if (( ${#rest} )); then
    print "unknown sb watch claude option: ${rest[1]}" >&2
    return 1
  fi

  if [[ -n "$acct" ]]; then
    _claude_require_account_name "$acct" || return 1
    transcript_path="$(_claude_latest_transcript_for_account "$acct")"
  else
    row="$(_claude_latest_transcript)"
    if [[ -n "$row" ]]; then
      acct="${row%%$'\t'*}"
      transcript_path="${row#*$'\t'}"
    fi
  fi

  if [[ -z "$transcript_path" ]]; then
    [[ -n "$acct" ]] && print "no Claude transcript yet for account '${acct}'" || print "no Claude transcript yet"
    return 1
  fi

  print "Tailing Claude transcript: account=${acct} path=${transcript_path}"
  exec tail -f "$transcript_path"
}

_claude_path_kind() {
  local target_path="$1"
  if [[ -L "$target_path" ]]; then
    echo "link -> $(readlink "$target_path")"
  elif [[ -e "$target_path" ]]; then
    echo "present"
  else
    echo "missing"
  fi
}

_claude_require_account_name() {
  local acct="$1"
  _valid_profile_name "$acct" || { print -P "%F{red}invalid Claude account name:%f ${acct}" >&2; return 1; }
}

_claude_link_path() {
  local src="$1" dst="$2" label="$3"
  [[ -e "$src" ]] || { print -P "%F{red}${label} source does not exist:%f ${src}" >&2; return 1; }
  if [[ -L "$dst" && "$(readlink "$dst")" == "$src" ]]; then
    return 0
  fi
  if [[ -e "$dst" || -L "$dst" ]]; then
    print -P "%F{yellow}${label} already exists, keeping:%f ${dst}" >&2
    return 0
  fi
  ln -s "$src" "$dst"
}

_claude_memory_note() {
  local acct="$1" dest="$2"
  cat > "$dest" <<EOF
# Claude profile: ${acct}

This is a Switchback-managed native Claude Code profile.
It keeps user-level Claude memory and local transcripts separate from ~/.claude.

Project-level CLAUDE.md files are still discovered by native Claude Code from the repo.
EOF
}

sb_claude_init() {  # sb_claude_init <account> [--copy-user-memory|--link-user-memory] [--link-agents]
  local acct="${1:-$SB_DEFAULT_CLAUDE_ACCOUNT}"; shift 2>/dev/null || true
  _claude_require_account_name "$acct" || return 1

  local copy_memory=0 link_memory=0 link_agents=0
  while (( $# )); do
    case "$1" in
      --copy-user-memory) copy_memory=1; shift ;;
      --link-user-memory) link_memory=1; shift ;;
      --link-agents) link_agents=1; shift ;;
      -h|--help)
        print "usage: sb claude init --account NAME [--copy-user-memory|--link-user-memory] [--link-agents]"
        return 0 ;;
      *) print "unknown claude init option: $1" >&2; return 1 ;;
    esac
  done
  if (( copy_memory && link_memory )); then
    print "choose only one of --copy-user-memory or --link-user-memory" >&2
    return 1
  fi

  local home; home="$(_claude_home "$acct")"
  mkdir -p "$home" "${home}/projects" "${home}/commands" "${home}/hooks" || return 1

  local global_memory="${HOME}/.claude/CLAUDE.md"
  local profile_memory="${home}/CLAUDE.md"
  if (( link_memory )); then
    _claude_link_path "$global_memory" "$profile_memory" "CLAUDE.md" || return 1
  elif (( copy_memory )) && [[ -f "$global_memory" && ! -e "$profile_memory" && ! -L "$profile_memory" ]]; then
    cp "$global_memory" "$profile_memory"
  elif [[ ! -e "$profile_memory" && ! -L "$profile_memory" ]]; then
    _claude_memory_note "$acct" "$profile_memory"
  fi

  local global_agents="${HOME}/.claude/agents"
  local profile_agents="${home}/agents"
  if (( link_agents )); then
    _claude_link_path "$global_agents" "$profile_agents" "agents" || return 1
  else
    mkdir -p "$profile_agents" || return 1
  fi

  print "Claude profile ready:"
  print "  account: ${acct}"
  print "  config: ${home}"
  print "  history: $(_claude_history_mode "$acct")"
  print "  memory: $(_claude_path_kind "$profile_memory")"
  print "  agents: $(_claude_path_kind "$profile_agents")"
  print "Run it: sb claude --account ${acct}"
}

sb_claude_accounts() {
  print "Claude accounts (native profiles):"
  local acct
  for acct in ${(f)"$(_claude_accounts_list)"}; do
    _valid_profile_name "$acct" || continue
    local home; home="$(_claude_home "$acct")"
    local n; n=$(find "${home}/projects" -name '*.jsonl' 2>/dev/null | wc -l | tr -d ' ')
    local marker="profile"
    [[ "$acct" == "$SB_DEFAULT_CLAUDE_ACCOUNT" ]] && marker="${marker}, default"
    [[ "$acct" == "default" ]] && marker="${marker}, native"
    print "  ${acct}  -> ${home}  (${marker}, history=$(_claude_history_mode "$acct"), ${n} transcripts)"
  done
  print "Add one: sb claude init --account <name> [--copy-user-memory|--link-user-memory] [--link-agents]"
}

sb_claude_doctor() {
  local acct="${1:-$SB_DEFAULT_CLAUDE_ACCOUNT}"
  _claude_require_account_name "$acct" || return 1
  local home; home="$(_claude_home "$acct")"
  print "Claude native profile:"
  print "  account: ${acct}"
  print "  mode: native"
  print "  config: ${home}"
  print "  history: $(_claude_history_mode "$acct")"
  print "  memory: $(_claude_path_kind "${home}/CLAUDE.md")"
  print "  agents: $(_claude_path_kind "${home}/agents")"
  print "  projects: $(_claude_path_kind "${home}/projects")"
  print "  native: ${NATIVE_CLAUDE}"
  print "  Switchback: native Claude is not proxied; use sb status / sb verify native for tap health."
  if [[ "$acct" != default && ! -d "$home" ]]; then
    print -P "  %F{yellow}next:%f sb claude init --account ${acct}"
    return 1
  fi
}

_run_claude() {  # _run_claude <mode> <account> [args...]
  local m="${1:-}" acct="${2:-$SB_DEFAULT_CLAUDE_ACCOUNT}"
  shift 1
  (( $# )) && shift 1
  _claude_require_account_name "$acct" || return 1
  case "$m" in
    native)
      local chome; chome="$(_claude_home "$acct")"
      if [[ "$acct" != default && ! -d "$chome" ]]; then
        print -P "%F{red}Claude profile '${acct}' does not exist.%f Create it: sb claude init --account ${acct}" >&2
        return 1
      fi
      print -P "%F{8}Claude native · account=${acct} · config=${chome} · history=$(_claude_history_mode "$acct") · Switchback=metadata-only%f" >&2
      if [[ "$acct" == default ]]; then
        exec command "$NATIVE_CLAUDE" "$@"
      fi
      CLAUDE_CONFIG_DIR="$chome" exec command "$NATIVE_CLAUDE" "$@" ;;
    free)
      [[ "$acct" == default ]] || print -P "%F{yellow}warning:%f --account only applies to native Claude profiles; free mode ignores '${acct}'%f" >&2
      _up || print -P "%F{yellow}warning:%f relay down%f" >&2
      exec "$FREE_CLAUDE" "$@" ;;
    *) print "unknown claude mode: $m"; return 1 ;;
  esac
}

sb_claude() {
  case "${1:-}" in
    accounts|list) shift 2>/dev/null || true; sb_claude_accounts "$@" ;;
    init) shift; SB_OPT_DEFAULT_ACCOUNT="$SB_DEFAULT_CLAUDE_ACCOUNT" _take_opts "$@"; sb_claude_init "$account" "${REST[@]}" ;;
    doctor) shift; SB_OPT_DEFAULT_ACCOUNT="$SB_DEFAULT_CLAUDE_ACCOUNT" _take_opts "$@"; sb_claude_doctor "$account" "${REST[@]}" ;;
    help|-h|--help)
      cat <<'EOF'
sb claude — native Claude Code profiles

  sb claude [--mode native|free] [--account NAME] [args]
  sb claude accounts
  sb claude init --account NAME [--copy-user-memory|--link-user-memory] [--link-agents]
  sb claude doctor --account NAME

Native mode launches the real Claude Code binary. Non-default accounts set
CLAUDE_CONFIG_DIR to ~/.config/switchback/claude/NAME, so user memory and
transcripts are profile-specific. Project CLAUDE.md files remain shared by repo.
EOF
      ;;
    *)
      SB_OPT_DEFAULT_ACCOUNT="$SB_DEFAULT_CLAUDE_ACCOUNT" _take_opts "$@"
      if [[ -n "$provider" ]]; then _run_claude_lane "$provider" "${REST[@]}"
      else _run_claude "${mode:-$SB_DEFAULT_CLAUDE_MODE}" "$account" "${REST[@]}"; fi ;;
  esac
}

sb_opencode() {
  _have opencode || { print "opencode not installed:  brew install sst/tap/opencode"; return 1; }
  _up || print -P "%F{yellow}warning:%f relay :18765 down — 'sb reload'" >&2
  print -P "opencode → Switchback gateway (:18765), observed."
  exec opencode "$@"
}

sb_pi() {
  _have pi || { print -P "%F{yellow}pi not installed:%f  npm install -g --ignore-scripts @earendil-works/pi-coding-agent"
                print "(Switchback provider already seeded in ~/.pi/agent/models.json)"; return 1; }
  _up || print -P "%F{yellow}warning:%f relay :18765 down — 'sb reload'" >&2
  print -P "pi → Switchback gateway (:18765), model ${SB_GW_MODEL}, observed."
  exec pi --provider switchback --model "$SB_GW_MODEL" "$@"
}

# ─────────────────────────── status / observe ───────────────────────────

sb_status() {
  print -P "%F{cyan}Switchback status%f"
  print "  relay (:18765):      $(_up && print -P '%F{green}UP%f' || print -P '%F{red}DOWN%f')"
  print "  claude tap (:18770): $(_listening 18770 && echo UP || echo down)"
  print "  codex  tap (:18771): $(_listening 18771 && echo UP || echo down)"
  if [[ -d "$SB_LANES" ]]; then
    local lf
    for lf in "$SB_LANES"/*.env(.N); do
      ( source "$lf"
        local k; [[ -n "$(_lane_keyval "$SB_LANE_KEY_ENV")" ]] && k="key✓" || k="key✗"
        print "  lane ${SB_LANE_NAME}: claude tap :${SB_LANE_ANTHROPIC_TAP:-–}$([[ -n "$SB_LANE_ANTHROPIC_TAP" ]] && { _listening "$SB_LANE_ANTHROPIC_TAP" && echo ↑ || echo ↓; }) · codex route ${SB_LANE_ROUTE:-–} · ${SB_LANE_MODEL} · ${k}" )
    done
  fi
  local native_json; native_json="$(_native_status_json || true)"
  if [[ -n "$native_json" ]]; then
    NATIVE_JSON="$native_json" python3 - <<'PY'
import json, os, sys
try:
  d=json.loads(os.environ.get("NATIVE_JSON", "{}"))
except Exception:
  sys.exit(0)
clients=d.get("clients", [])
if clients:
  print("  native fidelity:")
  for c in clients:
    tap=(c.get("modes", {}).get("native_tap", {}) or {})
    listener=tap.get("listener") or {}
    fid=c.get("fidelity", {}) or {}
    suffix=""
    if listener:
      suffix=f" · {listener.get('id','?')}@{listener.get('bind','?')} · capture={str(listener.get('capture_bodies', False)).lower()}"
    print(f"    {c.get('id','?'):<12} tap={tap.get('state','?'):<14} guarantee={fid.get('guarantee','?')}{suffix}")
for w in d.get("warnings", []):
  print(f"  warning: {w}")
for a in d.get("next_actions", []):
  print(f"  next: {a}")
PY
  fi
