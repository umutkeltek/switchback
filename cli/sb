_claude_remote_should_autostart() {
  local first="${1:-}"
  [[ $# -eq 0 ]] && return 0
  case "$first" in
    remote-control|rc|--remote-control|--rc|-p|--print|-h|--help|-v|--version|doctor|auth|mcp|agents|plugin|plugins|project|setup-token|install|gateway|auto-mode)
      return 1
      ;;
  esac
  return 0
}

_run_claude() {  # _run_claude <mode> <account> [args...]
  local m="${1:-}" acct="${2:-$SB_DEFAULT_CLAUDE_ACCOUNT}"
  shift 1
  (( $# )) && shift 1
  _claude_require_account_name "$acct" || return 1
case "$m" in
tap)
  local chome; chome="$(_claude_home "$acct")"
  if [[ "$acct" != default && ! -d "$chome" ]]; then
    print -P "%F{red}Claude profile '${acct}' does not exist.%f Create it: sb claude init --account ${acct}" >&2
    return 1
  fi
 _listening 18770 || print -P "%F{yellow}warning:%f claude tap :18770 not listening — sb reload%f" >&2
 print -P "%F{8}Claude tap · account=${acct} · config=${chome} · via 127.0.0.1:18770 → Headroom%f" >&2
 unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN
 if [[ "$acct" == default ]]; then
 ANTHROPIC_BASE_URL="http://127.0.0.1:18770" ENABLE_TOOL_SEARCH="${ENABLE_TOOL_SEARCH:-true}" exec command "$NATIVE_CLAUDE" "$@"
 fi
 CLAUDE_CONFIG_DIR="$chome" ANTHROPIC_BASE_URL="http://127.0.0.1:18770" ENABLE_TOOL_SEARCH="${ENABLE_TOOL_SEARCH:-true}" exec command "$NATIVE_CLAUDE" "$@" ;;
native)
      local chome; chome="$(_claude_home "$acct")"
      if [[ "$acct" != default && ! -d "$chome" ]]; then
        print -P "%F{red}Claude profile '${acct}' does not exist.%f Create it: sb claude init --account ${acct}" >&2
        return 1
      fi
 print -P "%F{8}Claude native · account=${acct} · config=${chome} · direct vendor escape hatch%f" >&2
 unset ANTHROPIC_BASE_URL ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN
 if [[ "$acct" == default ]]; then
 exec command "$NATIVE_CLAUDE" --setting-sources project,local "$@"
 fi
CLAUDE_CONFIG_DIR="$chome" exec command "$NATIVE_CLAUDE" --setting-sources project,local "$@" ;;
remote)
local chome; chome="$(_claude_home "$acct")"
if [[ "$acct" != default && ! -d "$chome" ]]; then
print -P "%F{red}Claude profile '${acct}' does not exist.%f Create it: sb claude init --account ${acct}" >&2
return 1
fi
_listening "$SB_MODE_D_PORT" || print -P "%F{yellow}warning:%f Mode D proxy :${SB_MODE_D_PORT} not listening; keep using tap/native until configured%f" >&2
[[ -r "$SB_MODE_D_CA_CERT" ]] || print -P "%F{yellow}warning:%f Mode D CA missing: ${SB_MODE_D_CA_CERT}%f" >&2
print -P "%F{8}Claude remote · account=${acct} · config=${chome} · HTTPS_PROXY=:${SB_MODE_D_PORT} · base URL unset%f" >&2
  unset ANTHROPIC_BASE_URL ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN
  local no_proxy_value="${NO_PROXY:-}"
  [[ -n "$no_proxy_value" ]] && no_proxy_value="${no_proxy_value},"
  no_proxy_value="${no_proxy_value}localhost,127.0.0.1,::1"
  local -a claude_args
  claude_args=(--setting-sources project,local)
  if _claude_remote_should_autostart "$@"; then
    claude_args+=(--remote-control)
  fi
  claude_args+=("$@")
  if [[ "$acct" == default ]]; then
    HTTPS_PROXY="http://127.0.0.1:${SB_MODE_D_PORT}" https_proxy="http://127.0.0.1:${SB_MODE_D_PORT}" NO_PROXY="$no_proxy_value" NODE_EXTRA_CA_CERTS="$SB_MODE_D_CA_CERT" exec command "$NATIVE_CLAUDE" "${claude_args[@]}"
  fi
  CLAUDE_CONFIG_DIR="$chome" HTTPS_PROXY="http://127.0.0.1:${SB_MODE_D_PORT}" https_proxy="http://127.0.0.1:${SB_MODE_D_PORT}" NO_PROXY="$no_proxy_value" NODE_EXTRA_CA_CERTS="$SB_MODE_D_CA_CERT" exec command "$NATIVE_CLAUDE" "${claude_args[@]}" ;;
free)
[[ "$acct" == default ]] || print -P "%F{yellow}warning:%f --account only applies to Claude subscription profiles; free mode ignores '${acct}'%f" >&2
      _up || print -P "%F{yellow}warning:%f relay down%f" >&2
      exec "$FREE_CLAUDE" "$@" ;;
    *) print "unknown claude mode: $m"; return 1 ;;
  esac
}

sb_claude() {
  case "${1:-}" in
    accounts|list) shift 2>/dev/null || true; sb_claude_accounts "$@" ;;
    init) shift; SB_OPT_DEFAULT_ACCOUNT="$SB_DEFAULT_CLAUDE_ACCOUNT" _take_opts "$@"; sb_claude_init "$account" "${REST[@]}" ;;
    doctor) shift; SB_OPT_DEFAULT_ACCOUNT="$SB_DEFAULT_CLAUDE_ACCOUNT" _take_opts "$@"; sb_claude_doctor "$account" "${REST[@]}" ;;
    help|-h|--help)
      cat <<'EOF'
sb claude — Claude Code profiles and modes

sb claude [--mode tap|native|remote|free] [--account NAME] [args]
sb claude accounts
sb claude init --account NAME [--copy-user-memory|--link-user-memory] [--link-agents]
sb claude doctor --account NAME

tap mode launches real Claude Code through the local Switchback tap at 127.0.0.1:18770.
native mode launches real Claude Code directly as an escape hatch.
remote mode launches real Claude Code with Remote Control enabled, base URL unset, and process-scoped HTTPS_PROXY through Mode D.
remote mode passes explicit Remote Control commands, --print, --help, and --version through unchanged.
Non-default accounts set CLAUDE_CONFIG_DIR to ~/.config/switchback/claude/NAME.
Project CLAUDE.md files remain shared by repo.
EOF
      ;;
    *)
      SB_OPT_DEFAULT_ACCOUNT="$SB_DEFAULT_CLAUDE_ACCOUNT" _take_opts "$@"
      if [[ -n "$provider" ]]; then _run_claude_lane "$provider" "${REST[@]}"
      else _run_claude "${mode:-$SB_DEFAULT_CLAUDE_MODE}" "$account" "${REST[@]}"; fi ;;
  esac
}

