sb_reload() {
  local response revision
  _up || { print -P "%F{red}relay down:%f cannot hot-reload ${GATEWAY}"; return 1; }
  response="$(curl -s -m 10 -X POST "${GATEWAY}/v1/reload" -H "content-type: application/json" -d '{}' 2>/dev/null)" || {
    print -P "%F{red}hot reload request failed%f"; return 1
  }
  if print -r -- "$response" | jq -e '.ok == true' >/dev/null 2>&1; then
    revision="$(print -r -- "$response" | jq -r '.revision // empty' 2>/dev/null)"
    print -P "%F{green}hot reload ok%f${revision:+ · revision ${revision}}"
  else
    print -P "%F{red}hot reload rejected:%f ${response}"; return 1
  fi
}

sb_restart() {
  if ! _have launchctl; then
    print -P "%F{yellow}'sb restart' uses macOS launchctl.%f Start the relay another way, e.g.:"
    print "  switchback serve --config ~/.config/switchback/switchback.yaml"; return 1
  fi
  print "Full relay restart (bootout + bootstrap)..."
  launchctl bootout "gui/$(id -u)/${SB_LAUNCH_LABEL}" 2>/dev/null; sleep 1
  launchctl bootstrap "gui/$(id -u)" "$PLIST"
  local i; for i in {1..20}; do _up && { print -P '%F{green}relay up%f'; break; }; sleep 0.4; done
}

