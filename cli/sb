_local_status_json() {
local base routes loaded fetched_at
base="$(_local_lmstudio_base_url)"
routes="$(_switchback config get routes --json --config "$SB_CONFIG" 2>/dev/null)" || routes="[]"
loaded="$(_local_loaded_ids_json 2>/dev/null)" || loaded="[]"
fetched_at="$(date -u "+%Y-%m-%dT%H:%M:%SZ")"
jq -n \
--arg provider "lmstudio" \
--arg provider_id "mac" \
--arg base_url "$base" \
--arg fetched_at "$fetched_at" \
--argjson routes_cfg "$routes" \
--argjson loaded "$loaded" '
def route_target($route):
  first($routes_cfg[]? | select((.match.model // "") == $route) | .targets[0]) // null;
def target_identifier($target):
  if $target == null then null else ($target | sub("^mac/"; "")) end;
def route_status($target):
  if $target == null then "unset"
  elif any($loaded[]; . == target_identifier($target)) then "loaded"
  else "stale"
  end;
def route_row($slot; $route):
  route_target($route) as $target |
  route_status($target) as $status |
  {
    slot: $slot,
    route: $route,
    target: $target,
    target_identifier: target_identifier($target),
    status: $status,
    loaded: ($status == "loaded"),
    suggestion: (
      if ($status != "loaded" and ($loaded | length) > 0)
      then "sb local use \($slot) \($loaded[0]) --reload"
      else null
      end
    )
  };
([route_row("code"; "local/mac-code"), route_row("fast"; "local/mac-fast")]) as $rows |
{
  provider: $provider,
  provider_id: $provider_id,
  base_url: $base_url,
  fetched_at: $fetched_at,
  served_models: $loaded,
  served_count: ($loaded | length),
  loaded_models: $loaded,
  loaded_count: ($loaded | length),
  routes: $rows,
  ok: all($rows[]; .status == "loaded")
}'
}

_local_current() {
local json=0 status_json count
while (( $# )); do
case "$1" in
--json|-j) json=1; shift ;;
-h|--help) cat <<'EOF'
sb local current [--json]

Shows LM Studio live loaded models and reconciles them against Switchback
local routes. JSON output is intended for agents and scripts.
EOF
return 0 ;;
*) print "unknown local current flag: $1"; return 1 ;;
esac
done
status_json="$(_local_status_json)" || return 1
if (( json )); then
print -r -- "$status_json"
return 0
fi
print -P "%F{cyan}LM Studio live provider%f"
print " base_url: $(print -r -- "$status_json" | jq -r '.base_url')"
count="$(print -r -- "$status_json" | jq -r '.served_count')"
print " served: ${count}"
print ""
print -P "%F{cyan}Switchback local routes%f"
print -r -- "$status_json" | jq -r '.routes[] |
  " \(.route) -> \(.target // "unset") [" + .status + "]" +
  (if .suggestion then "\n   fix: " + .suggestion else "" end)'
print ""
print -P "%F{cyan}LM Studio served model ids%f"
print -r -- "$status_json" | jq -r '.served_models[]?'
if _have lms; then
print ""
print -P "%F{cyan}LM Studio loaded processes%f"
_local_models || true
fi
}

_local_use() {
local slot="${1:-}" ident="${2:-}" reload=0 route target routes patched
shift 2 2>/dev/null || true
while (( $# )); do
case "$1" in
--reload) reload=1; shift ;;
*) print "unknown flag: $1"; return 1 ;;
esac
done
route="$(_local_slot_route "$slot" 2>/dev/null)" || {
print "usage: sb local use <code|fast> <loaded-lmstudio-identifier> [--reload]"
return 1
}
[[ -n "$ident" ]] || {
print "usage: sb local use <code|fast> <loaded-lmstudio-identifier> [--reload]"
print ""
_local_models || true
return 1
}
if ! _local_loaded_ids | grep -Fx -- "$ident" >/dev/null; then
print -P "%F{red}LM Studio identifier is not loaded:%f $ident" >&2
print "Loaded identifiers:" >&2
_local_loaded_ids >&2 || true
return 1
fi
target="mac/${ident#mac/}"
routes="$(_switchback config get routes --json --config "$SB_CONFIG" 2>/dev/null)" || {
print -P "%F{red}cannot read Switchback routes%f" >&2
return 1
}
patched="$(ROUTES="$routes" ROUTE="$route" TARGET="$target" python3 - <<'PY'
import json, os, sys
routes = json.loads(os.environ["ROUTES"])
route = os.environ["ROUTE"]
target = os.environ["TARGET"]
changed = False
for item in routes:
    if isinstance(item, dict) and (item.get("match") or {}).get("model") == route:
        if item.get("targets") != [target]:
            item["targets"] = [target]
            changed = True
        break
else:
    sys.exit(2)
print(json.dumps({"changed": changed, "routes": routes}))
PY
)" || {
print -P "%F{red}route not found:%f $route" >&2
return 1
}
if print -r -- "$patched" | jq -e '.changed == false' >/dev/null 2>&1; then
print "${route} already -> ${target}"
return 0
fi
print -r -- "$patched" | jq -c '.routes' >/tmp/sb-local-routes.json
_switchback config set routes "$(cat /tmp/sb-local-routes.json)" --config "$SB_CONFIG" >/dev/null || return 1
_switchback config validate --config "$SB_CONFIG" >/dev/null || return 1
print -P "%F{green}${route}%f -> ${target}"
if (( reload )); then
sb_reload
else
print -P "config changed -> run %F{cyan}sb reload%f when active sessions are safe"
fi
}

sb_local() {
local sub="${1:-current}"
[[ $# -gt 0 ]] && shift
case "$sub" in
models|ps) _local_models "$@" ;;
current|status|served|"") _local_current "$@" ;;
use) _local_use "$@" ;;
help|-h|--help) cat <<'EOF'
sb local — LM Studio route selection

sb local models
sb local current [--json]
sb local served [--json]
sb local use code <loaded-identifier> [--reload]
sb local use fast <loaded-identifier> [--reload]

Use `lms ps` identifiers, e.g.
  sb local use code qwen3.6-27b-uncensored-hauhaucs-aggressive --reload
EOF
;;
*) print "unknown local command: $1"; return 1 ;;
esac
}

