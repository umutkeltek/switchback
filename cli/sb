_probe_body_summary() {
local file="$1" summary=""
if _have jq && [[ -s "$file" ]]; then
summary="$(jq -r '
  if type == "object" then
    (.error.message // .error.details // .error // .message // empty)
  else empty end
' "$file" 2>/dev/null | head -n 1)"
fi
if [[ -z "$summary" && -s "$file" ]]; then
summary="$(tr '\n' ' ' < "$file" | cut -c1-220)"
fi
print -r -- "$summary"
}

_probe_print_result() {
local label="$1" code="$2" file="$3" summary
summary="$(_probe_body_summary "$file")"
case "$code" in
2??) print -P " %F{green}✓%f ${label}: HTTP ${code}${summary:+ — ${summary}}" ;;
401) print -P " %F{red}✗%f ${label}: HTTP 401 auth failed${summary:+ — ${summary}}" ;;
402) print -P " %F{red}✗%f ${label}: HTTP 402 billing/credits exhausted${summary:+ — ${summary}}" ;;
403) print -P " %F{red}✗%f ${label}: HTTP 403 unauthorized${summary:+ — ${summary}}" ;;
429) print -P " %F{yellow}•%f ${label}: HTTP 429 rate limited${summary:+ — ${summary}}" ;;
529) print -P " %F{yellow}•%f ${label}: HTTP 529 overloaded${summary:+ — ${summary}}" ;;
5??) print -P " %F{yellow}•%f ${label}: HTTP ${code} upstream/server error${summary:+ — ${summary}}" ;;
000) print -P " %F{red}✗%f ${label}: no HTTP response${summary:+ — ${summary}}" ;;
*) print -P " %F{yellow}•%f ${label}: HTTP ${code}${summary:+ — ${summary}}" ;;
esac
}

_probe_json_endpoint() {
local label="$1" url="$2" key_env="$3" body="$4"
shift 4
local key tmp err code rc timeout
timeout="${SB_PROVIDER_DOCTOR_TIMEOUT:-35}"
key="$(_lane_keyval "$key_env")"
if [[ -z "$key" ]]; then
print -P " %F{red}✗%f ${label}: ${key_env} is not set"
return 2
fi
tmp="$(mktemp)"
err="${tmp}.err"
code="$(curl -sS -m "$timeout" -o "$tmp" -w "%{http_code}" "$url" \
  -H "authorization: Bearer ${key}" \
  -H "content-type: application/json" \
  "$@" \
  -d "$body" 2>"$err")"
rc=$?
if (( rc != 0 )); then
print -P " %F{red}✗%f ${label}: curl failed (${rc})$([[ -s "$err" ]] && print -r -- " — $(tr '\n' ' ' < "$err" | cut -c1-180)")"
rm -f "$tmp" "$err"
return $rc
fi
_probe_print_result "$label" "$code" "$tmp"
rm -f "$tmp" "$err"
[[ "$code" == 2?? ]]
}

