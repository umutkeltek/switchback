sb_modes_generate() {
local dir="${HOME}/.local/bin" dry=0 repo=0
while (( $# )); do
case "$1" in
--dir) dir="${2:-}"; shift 2 ;;
--dir=*) dir="${1#--dir=}"; shift ;;
--repo) repo=1; shift ;;
--dry-run) dry=1; shift ;;
*) print "unknown flag: $1"; return 1 ;;
esac
done
(( repo )) && dir="${0:A:h}/wrappers"
[[ -n "$dir" ]] || { print "missing --dir"; return 1; }

local -a entries
entries=("${(@f)$(_mode_wrapper_spec)}")
setopt local_options null_glob
local f
for f in "$SB_LANES"/*.env; do
source "$f" 2>/dev/null || continue
[[ -n "${SB_LANE_NAME:-}" ]] || continue
entries+=("codex-${SB_LANE_NAME}|sb run codex --with ${SB_LANE_NAME}")
entries+=("claude-${SB_LANE_NAME}|sb run claude --with ${SB_LANE_NAME}")
[[ -n "${SB_LANE_DIRECT_ROUTE:-}" ]] && entries+=("codex-${SB_LANE_NAME}-direct|sb run codex --with ${SB_LANE_NAME}-direct")
[[ -n "${SB_LANE_ANTHROPIC_URL:-}" ]] && entries+=("claude-${SB_LANE_NAME}-direct|sb run claude --with ${SB_LANE_NAME}-direct")
done

(( dry )) || mkdir -p "$dir"
typeset -A seen
local line name cmd path body count=0
for line in "${entries[@]}"; do
[[ "$line" == *"|"* ]] || continue
name="${line%%|*}"
cmd="${line#*|}"
[[ -n "$name" && -n "$cmd" ]] || continue
[[ -n "${seen[$name]:-}" ]] && continue
seen[$name]=1
path="${dir}/${name}"
body=$'#!/bin/zsh\n'"exec ${cmd} \"\$@\""$'\n'
if (( dry )); then
print -r -- "${path} -> ${cmd}"
else
print -r -- "$body" > "$path"
if [[ -x /bin/chmod ]]; then /bin/chmod +x "$path"; else chmod +x "$path"; fi
fi
(( count++ ))
done
if (( dry )); then
print "would generate ${count} mode wrappers"
else
print "generated ${count} mode wrappers in ${dir}"
fi
}

