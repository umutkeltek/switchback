  setopt local_options null_glob
  local f found=0
  for f in "$SB_LANES"/*.env; do
    found=1
    source "$f"
local kp="" ks=""
ks="$(_lane_secret_status "$SB_LANE_NAME" "$SB_LANE_KEY_ENV")"
case "$ks" in
env) kp="%F{green}set%f" ;;
vault:*) kp="%F{green}${ks}%f" ;;
*) kp="%F{yellow}unset -> sb lane key ${SB_LANE_NAME}%f" ;;
esac
    print -P " %F{cyan}${SB_LANE_NAME}%f model=${SB_LANE_MODEL} key[${SB_LANE_KEY_ENV}]=${kp}"
    if [[ -n "$SB_LANE_ANTHROPIC_TAP" ]]; then
