        return "+".join(modes)
    return "text+image" if row.get("vision") else "text"

def output_modes(row):
    caps = row.get("capabilities") or {}
    modes = caps.get("output_modalities")
    return "+".join(modes) if modes else "text"

def bench_summary(row):
    benches = row.get("benchmarks") or {}
    parts = []
    if "openrouter" in benches:
        values = benches["openrouter"].get("values") or {}
        aa = values.get("artificial_analysis") or {}
        if aa:
            parts.append(
                "AA "
                + "/".join(
                    f"{k.split('_')[0]}={v}"
                    for k, v in aa.items()
                    if k in {"intelligence_index", "coding_index", "agentic_index"}
                )
            )
        design = values.get("design_arena") or []
        if design:
            best = sorted(design, key=lambda x: x.get("rank") or 9999)[0]
            parts.append(f"Design {best.get('category')}#{best.get('rank')} elo={best.get('elo')}")
    if "vendor" in benches:
        values = benches["vendor"].get("values") or {}
        parts.extend([f"{k}={v}" for k, v in list(values.items())[:3]])
    return "; ".join(parts) or "-"

def arch_summary(row):
  arch = row.get("architecture") or {}
  bits = []
  if arch.get("mixture_of_experts"):
    bits.append("MoE")
    if arch.get("parameters_total_b"):
        bits.append(f"{arch.get('parameters_total_b')}B")
    if arch.get("parameters_active_b"):
        bits.append(f"{arch.get('parameters_active_b')}B active")
  if arch.get("architecture_type"):
    bits.append(short(arch.get("architecture_type"), 24))
  elif arch.get("attention"):
    bits.append(short(arch.get("attention"), 24))
  elif arch.get("context_method"):
    bits.append(short(arch.get("context_method"), 24))
  elif arch.get("tokenizer"):
    bits.append(str(arch.get("tokenizer")))
  return " ".join(bits) or "-"

def print_models(rows):
    print("provider model in/Mtok out/Mtok ctx notes")
