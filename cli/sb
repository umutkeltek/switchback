import json
import sys
from datetime import datetime, timezone

path, mode, flt = sys.argv[1], sys.argv[2], sys.argv[3].lower()
with open(path) as f:
    data = json.load(f)

providers = data.get("providers", [])
models = data.get("models", [])
now = datetime.now(timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z")

def money(v):
 if v is None:
  return "?"
 if v == 0:
  return "$0"
 return f"${v / 1_000_000:.4g}"
def usd_per_mtok(v):
 if v is None:
  return None
 return v / 1_000_000

def short(text, n):
    text = "" if text is None else str(text)
    return text if len(text) <= n else text[: max(0, n - 3)] + "..."

def row_text(row):
    caps = row.get("capabilities") or {}
    arch = row.get("architecture") or {}
    benches = row.get("benchmarks") or {}
    return " ".join([
        f"{row.get('provider_id', '')}/{row.get('model_id', '')}",
        row.get("provider_id", ""),
        row.get("model_id", ""),
        row.get("display_name", ""),
        " ".join(row.get("flags") or []),
        " ".join(caps.get("input_modalities") or []),
        " ".join(caps.get("output_modalities") or []),
        " ".join(caps.get("supported_parameters") or []),
        str(arch.get("architecture_type", "")),
        str(arch.get("tokenizer", "")),
        " ".join(benches.keys()),
    ]).lower()

def model_key(row):
    return f"{row.get('provider_id', '')}/{row.get('model_id', '')}".lower()

def active(row):
    return not (row.get("effective_to") and row["effective_to"] <= now)

def keep_model(row):
    if not active(row):
        return False
    if flt:
        if mode == "model" and "/" in flt:
            return flt == model_key(row) or flt == str(row.get("model_id", "")).lower()
        return flt in row_text(row)
    return row.get("provider_id") in {"nvidia", "openrouter", "deepseek"} or row.get("input_micros_per_mtok") == 0

def json_schema(row):
    caps = row.get("capabilities") or {}
