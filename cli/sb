#!/bin/zsh
# sb — Switchback control. One front door for every AI tool, observed through
# Switchback. Run `sb` (no args) for the interactive menu (arrows ↑↓ · Enter ·
# Esc), or use subcommands directly. "Smart default + quick switch": each tool
# has a default mode you can run instantly or override per run.
#
#   Relay (LaunchAgent ai.switchback.scout) serves ~/.config/switchback/switchback.yaml
#   on :18765, with transparent taps on :18770 (claude) / :18771 (codex).
#   Live settings + defaults live in ~/.config/switchback/sb.env.
set -uo pipefail

SB_CLI_PATH="${0:A}"
SB_CONFIG="${HOME}/.config/switchback/switchback.yaml"
SB_ENV="${HOME}/.config/switchback/sb.env"
SB_STATE="${HOME}/.local/state/switchback"
SB_MODE_D_PORT="${SB_MODE_D_PORT:-18780}"
SB_MODE_D_GATEWAY="${SB_MODE_D_GATEWAY:-http://127.0.0.1:18865}"
SB_MODE_D_CONFIG="${SB_MODE_D_CONFIG:-${HOME}/.config/switchback/mode-d.yaml}"
SB_MODE_D_CA_CERT="${SB_MODE_D_CA_CERT:-${SB_STATE}/mode-d/ca.pem}"
CODEX_PROFILES="${CODEX_PROFILES:-${HOME}/.config/switchback/codex}"
CLAUDE_PROFILES="${CLAUDE_PROFILES:-${HOME}/.config/switchback/claude}"
SB_PROVIDER_REGISTRY="${SB_PROVIDER_REGISTRY:-${HOME}/Projects/systems/switchback/config/provider-registry.json}"
SB_LANES="${SB_LANES:-${HOME}/.config/switchback/lanes}"   # coding-plan provider lanes (claude=verbatim tap, codex=engine relay)
GATEWAY="${SB_GATEWAY:-http://127.0.0.1:18765}"
SB_LAUNCH_LABEL="${SB_LAUNCH_LABEL:-ai.switchback.scout}"
PLIST="${SB_PLIST:-${HOME}/Library/LaunchAgents/${SB_LAUNCH_LABEL}.plist}"
FZF="$(command -v fzf || true)"

# Shared-session-mode plumbing (overridable for tests). In SHARED mode the default
# account uses the native ~/.codex pool; named accounts auto-isolate unless the
# user explicitly opts into the shared pool. Shared-pool auth swaps are guarded
# because ~/.codex/auth.json is process-global mutable state.
SB_MAIN_HOME="${SB_MAIN_HOME:-${HOME}/.codex}"
SB_AUTHREG="${SB_AUTHREG:-${HOME}/.config/switchback/codex-auth}"
SB_ACTIVE_FILE="${SB_AUTHREG}/.active"
SB_RUNS_FILE="${SB_AUTHREG}/.runs"
SB_LOCK_DIR="${SB_AUTHREG}/.lock"

# mode → command (codex). CODEX_HOME is set per account before exec.
TAP_WRAPPER="${HOME}/.local/bin/codex-switchback-tap"
RELAY_WRAPPER="${HOME}/.local/bin/codex-switchback-traced"
FREE_WRAPPER="${HOME}/.local/bin/codex-switchback-scout"
# Real binaries auto-detected from PATH (override with SB_NATIVE_CODEX / SB_NATIVE_CLAUDE).
NATIVE_CODEX="${SB_NATIVE_CODEX:-$(command -v codex 2>/dev/null || echo ${HOME}/.bun/bin/codex)}"
NATIVE_CLAUDE="${SB_NATIVE_CLAUDE:-$(command -v claude 2>/dev/null || echo ${HOME}/.local/bin/claude)}"
FREE_CLAUDE="${HOME}/.local/bin/claude-switchback-scout"

# Defaults (overridable via sb.env / Settings).
[ -f "$SB_ENV" ] && source "$SB_ENV"
SB_DEFAULT_CODEX_MODE="${SB_DEFAULT_CODEX_MODE:-tap}"
SB_DEFAULT_CLAUDE_MODE="${SB_DEFAULT_CLAUDE_MODE:-tap}"
SB_DEFAULT_ACCOUNT="${SB_DEFAULT_ACCOUNT:-default}"
SB_DEFAULT_CLAUDE_ACCOUNT="${SB_DEFAULT_CLAUDE_ACCOUNT:-$SB_DEFAULT_ACCOUNT}"
SB_CODEX_MODEL="${SB_CODEX_MODEL:-gpt-5.5}"
SB_CODEX_EFFORT="${SB_CODEX_EFFORT:-xhigh}"
SB_GW_MODEL="${SB_GW_MODEL:-openrouter}"
SB_LMSTUDIO_CODE_ROUTE="${SB_LMSTUDIO_CODE_ROUTE:-local/mac-code}"
SB_LMSTUDIO_FAST_ROUTE="${SB_LMSTUDIO_FAST_ROUTE:-local/mac-fast}"
OPENCODE_LMSTUDIO_MODEL="${OPENCODE_LMSTUDIO_MODEL:-lmstudio/qwen/qwen3-coder-30b}"
OPENCODE_GO_MODEL="${OPENCODE_GO_MODEL:-glm-5.2}"
# Default 'shared' = how native Codex already works: one active account in the
# ~/.codex pool. 'separated' is the concurrent-safe isolation mode (own CODEX_HOME).
SB_SESSION_MODE="${SB_SESSION_MODE:-shared}"      # shared | separated

_up()        { curl -s -m 2 "${GATEWAY}/health" >/dev/null 2>&1; }
_listening() { /usr/sbin/lsof -nP -iTCP:"$1" -sTCP:LISTEN -t >/dev/null 2>&1; }
_have()      { command -v "$1" >/dev/null 2>&1; }
_switchback_repo_root() {
local root="${SWITCHBACK_ROOT:-${SB_CLI_PATH:h:h}}"
[[ -f "${root}/tools/probe-provider-registry.ts" ]] || root="${HOME}/Projects/systems/switchback"
print -r -- "$root"
}

_route_preview_selected() {
local model="$1" body
_have jq || return 1
body="$(curl -s -m 2 "${GATEWAY}/cp/v1/route-preview" -H "content-type: application/json" -d "{\"model\":\"${model}\",\"messages\":[{\"role\":\"user\",\"content\":\"route preview\"}]}" 2>/dev/null)" || return 1
print -r -- "$body" | jq -r '.decision.selected.target_id // empty' 2>/dev/null
}
_route_config_target() {
local route="$1" routes
_have jq || return 1
routes="$(_switchback config get routes --json --config "$SB_CONFIG" 2>/dev/null)" || return 1
print -r -- "$routes" | jq -r --arg route "$route" 'first(.[]? | select((.match.model // "") == $route) | .targets[0]) // empty' 2>/dev/null
}
_route_active_or_warn() {
local route="$1" body selected reason_route expected_target
body="$(curl -s -m 2 "${GATEWAY}/cp/v1/route-preview" -H "content-type: application/json" -d "{\"model\":\"${route}\",\"messages\":[{\"role\":\"user\",\"content\":\"route preview\"}]}" 2>/dev/null)" || body=""
selected="$(print -r -- "$body" | jq -r '.decision.selected.target_id // empty' 2>/dev/null)"
reason_route="$(print -r -- "$body" | jq -r --arg route "route=${route}" 'any(.decision.reason[]?; . == $route)' 2>/dev/null)"
expected_target="$(_route_config_target "$route" 2>/dev/null)"
[[ -n "$expected_target" ]] || expected_target="${route%%/*}-coding/${route#*/}"
  if [[ -z "$selected" || ( "$selected" != "$route" && "$selected" != "$expected_target" && "$reason_route" != "true" ) ]]; then
    print -P "%F{red}${route} is configured on disk but not active in the running engine.%f" >&2
    print -P "Reload when active sessions are safe: %F{cyan}sb reload%f" >&2
    return 1
  fi
  return 0
}
_pause()     { print -n "\n  (Enter to continue) "; read -r _; }
_codex_home(){ [[ "$1" == "default" ]] && echo "${HOME}/.codex" || echo "${CODEX_PROFILES}/$1"; }
_accounts_list() { { echo default; ls "${CODEX_PROFILES}" 2>/dev/null; } | awk 'NF'; }
_claude_home(){ [[ "$1" == "default" ]] && echo "${HOME}/.claude" || echo "${CLAUDE_PROFILES}/$1"; }
_claude_accounts_list() { { echo default; ls "${CLAUDE_PROFILES}" 2>/dev/null; } | awk 'NF'; }
_provider_home() {
  local root="$1" label="$2" safe
  safe="${label//[^A-Za-z0-9._-]/_}"
  local home="${root}/_providers/${safe}"
  mkdir -p "$home" || return 1
  print -r -- "$home"
}
_codex_provider_home() { _provider_home "$CODEX_PROFILES" "$1"; }
_claude_provider_home() { _provider_home "$CLAUDE_PROFILES" "$1"; }
_claude_on_demand_mcp_config() {
local chome="$1" spec="${2:-gbrain}" source legacy out tmp
source="$(_claude_user_config_dir)/mcp-on-demand.json"
legacy="$(_claude_user_config_dir)/.mcp.json"

if [[ "$spec" == "legacy" ]]; then
[[ -f "$legacy" ]] && print -r -- "$legacy"
return 0
fi

if [[ ! -f "$source" ]]; then
[[ -f "$legacy" ]] && print -r -- "$legacy"
return 0
fi

_have jq || {
[[ -f "$legacy" ]] && print -r -- "$legacy"
return 0
}

mkdir -p "$chome" || return 1
out="${chome}/switchback-mcp.generated.json"
tmp="$(mktemp)" || return 1

jq --arg spec "$spec" '
def wanted:
if ($spec | ascii_downcase) == "all" then null
else $spec | split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(. != ""))
end;
def claude_env_value:
if type == "string" then .
elif type == "number" or type == "boolean" then tostring
elif type == "object" and .["$secret"].provider == "env" and (env[.["$secret"].id] != null) then env[.["$secret"].id]
else empty
end;
def claude_server:
if (.env | type) == "object" then
. + {env: (.env | with_entries(.value = (.value | claude_env_value)))}
else .
end;
(.claude // {}) as $servers
| (wanted) as $wanted
| {
mcpServers:
(if $wanted == null then
($servers | with_entries(.value = (.value | claude_server)))
else
reduce $wanted[] as $name ({}; if $servers[$name] != null then . + {($name): ($servers[$name] | claude_server)} else . end)
end)
}
| select((.mcpServers | length) > 0)
' "$source" >| "$tmp" 2>/dev/null || {
rm -f "$tmp"
return 1
}

if [[ ! -s "$tmp" ]]; then
rm -f "$tmp"
return 1
fi

mv "$tmp" "$out" || {
rm -f "$tmp"
return 1
}
chmod 600 "$out" 2>/dev/null || true
print -r -- "$out"
}
_switchback() {
local bin="${SB_BIN:-$(command -v switchback 2>/dev/null || true)}"
if [[ -z "$bin" ]]; then
print -P "%F{red}switchback binary not found on PATH%f" >&2
return 127
  fi
  command "$bin" "$@"
}

_tap_capture_state() {
  _have jq || { print -r -- "unknown"; return 1; }
  local taps
  taps="$(_switchback config get server.taps --json --config "$SB_CONFIG" 2>/dev/null)" || { print -r -- "invalid"; return 1; }
  print -r -- "$taps" | jq -r 'if ((type != "array") or (length == 0)) then "none" elif any(.[]; (.capture_bodies | type) != "boolean") then "invalid" elif all(.[]; .capture_bodies == true) then "true" elif all(.[]; .capture_bodies == false) then "false" else "mixed" end' 2>/dev/null
}

_set_tap_capture_bodies() {
  local desired="$1" taps updated
  case "$desired" in
    on|true) desired=true ;;
    off|false) desired=false ;;
    *) print "usage: sb capture on|off" >&2; return 2 ;;
  esac

  _have jq || { print -P "%F{red}jq is required for safe capture edits%f" >&2; return 127; }
  taps="$(_switchback config get server.taps --json --config "$SB_CONFIG" 2>/dev/null)" || {
    print -P "%F{red}Cannot read server.taps; config is not parseable. Not changing capture.%f" >&2
    return 1
  }
  print -r -- "$taps" | jq -e '((type == "array") and (length > 0) and all(.[]; (.capture_bodies | type) == "boolean"))' >/dev/null 2>&1 || {
    print -P "%F{red}Refusing capture edit: server.taps capture_bodies is missing or not boolean.%f" >&2
    print -P "Repair the config first, then rerun %F{cyan}sb capture on|off%f." >&2
    return 1
  }
  updated="$(print -r -- "$taps" | jq -c --argjson desired "$desired" 'map(.capture_bodies = $desired)')" || return 1
  _switchback config set server.taps "$updated" --config "$SB_CONFIG" >/dev/null || return 1
  _switchback config validate --config "$SB_CONFIG" >/dev/null || return 1
  print -P "capture_bodies → %F{cyan}${desired}%f (saved; not reloaded)"
  print "Reload when no active sessions are using the taps: sb reload"
}

_native_status_json() { _switchback --json native status --config "$SB_CONFIG" 2>/dev/null; }
_native_profiles_json() { _switchback --json native profiles list --config "$SB_CONFIG" 2>/dev/null; }

# Pull --account/--mode/--sessions/--provider out of args → sets `account`, `mode`,
# `sessmode`, `provider`, REST.
_take_opts() {
  account="${SB_OPT_DEFAULT_ACCOUNT:-$SB_DEFAULT_ACCOUNT}"; mode=""; sessmode=""; provider=""; local -a rest=()
  while (( $# )); do
    case "$1" in
      --account) account="${2:-default}"; shift 2 ;;
      --account=*) account="${1#--account=}"; shift ;;
      --mode) mode="${2:-}"; shift 2 ;;
      --mode=*) mode="${1#--mode=}"; shift ;;
      --sessions) sessmode="${2:-}"; shift 2 ;;
      --sessions=*) sessmode="${1#--sessions=}"; shift ;;
      --provider) provider="${2:-}"; shift 2 ;;
      --provider=*) provider="${1#--provider=}"; shift ;;
      *) rest+=("$1"); shift ;;
    esac
  done
  REST=("${rest[@]}")
}

# ── shared-session credential registry (refresh-safe auth.json swap) ──────────
_authreg_path() { echo "${SB_AUTHREG}/$1.json"; }
_shared_active() { cat "$SB_ACTIVE_FILE" 2>/dev/null || echo default; }

_shared_lock_acquire() {
  mkdir -p "$SB_AUTHREG" || return 1
  local i=0
  while ! mkdir "$SB_LOCK_DIR" 2>/dev/null; do
    if (( i >= 200 )); then
      print -P "%F{red}could not acquire shared Codex auth lock%f: ${SB_LOCK_DIR}" >&2
      return 1
    fi
    (( i++ ))
    sleep 0.05
  done
}

_shared_lock_release() { rmdir "$SB_LOCK_DIR" 2>/dev/null || true; }

_shared_prune_runs_locked() {
  [[ -f "$SB_RUNS_FILE" ]] || return 0
  local tmp; tmp="$(mktemp)" || return 1
  local pid acct started
  while IFS=$'\t' read -r pid acct started; do
    [[ "$pid" == <-> ]] || continue
    kill -0 "$pid" 2>/dev/null || continue
    print -r -- "${pid}"$'\t'"${acct}"$'\t'"${started}" >> "$tmp"
  done < "$SB_RUNS_FILE"
  mv "$tmp" "$SB_RUNS_FILE"
}

_shared_conflicts_locked() {
  local want="$1" pid acct started
  _shared_prune_runs_locked
  [[ -f "$SB_RUNS_FILE" ]] || return 0
  while IFS=$'\t' read -r pid acct started; do
    [[ -n "$pid" && -n "$acct" ]] || continue
    [[ "$acct" == "$want" ]] && continue
    print -r -- "${pid}"$'\t'"${acct}"$'\t'"${started}"
  done < "$SB_RUNS_FILE"
}

_shared_register_run_locked() {
  local acct="$1" pid="${2:-$$}" tmp started
  started="$(date +%Y%m%d-%H%M%S)"
  touch "$SB_RUNS_FILE" || return 1
  tmp="$(mktemp)" || return 1
  awk -F '\t' -v pid="$pid" '$1 != pid { print }' "$SB_RUNS_FILE" > "$tmp"
  print -r -- "${pid}"$'\t'"${acct}"$'\t'"${started}" >> "$tmp"
  mv "$tmp" "$SB_RUNS_FILE"
}

_shared_unregister_run_locked() {
  local pid="${1:-$$}" tmp
  [[ -f "$SB_RUNS_FILE" ]] || return 0
  tmp="$(mktemp)" || return 1
  awk -F '\t' -v pid="$pid" '$1 != pid { print }' "$SB_RUNS_FILE" > "$tmp"
  mv "$tmp" "$SB_RUNS_FILE"
}

_shared_run_label() {
  local acct="$1"
  case "$acct" in
    __exclusive:*) print -r -- "${acct#__exclusive:}" ;;
    *) print -r -- "$acct" ;;
  esac
}

_shared_first_run_locked() {
  _shared_prune_runs_locked
  [[ -f "$SB_RUNS_FILE" ]] || return 0
  local pid acct started
  while IFS=$'\t' read -r pid acct started; do
    [[ -n "$pid" && -n "$acct" ]] || continue
    print -r -- "${pid}"$'\t'"${acct}"$'\t'"${started}"
    return 0
  done < "$SB_RUNS_FILE"
}

_shared_begin_exclusive_run() {
  local label="$1" pid="${2:-$$}" first other_pid other_acct other_started
  _shared_lock_acquire || return 1
  first="$(_shared_first_run_locked)"
  if [[ -n "$first" ]]; then
    IFS=$'\t' read -r other_pid other_acct other_started <<< "$first"
    print -P "%F{red}Cannot ${label} while shared Codex pool is active as '$(_shared_run_label "$other_acct")' (pid ${other_pid}).%f" >&2
    print -P "Wait for that run to finish, then retry." >&2
    _shared_lock_release
    return 1
  fi
  _shared_register_run_locked "__exclusive:${label}" "$pid" || { _shared_lock_release; return 1; }
  _shared_lock_release
}

_shared_end_exclusive_run() {
  local pid="${1:-$$}"
  _shared_lock_acquire || return 0
  _shared_unregister_run_locked "$pid"
  _shared_lock_release
}

_shared_print_active_runs() {
  _shared_lock_acquire || { print "  active shared runs: unknown (lock busy)"; return 0; }
  _shared_prune_runs_locked
  local -a rows; rows=()
  local pid acct started
  if [[ -f "$SB_RUNS_FILE" ]]; then
    while IFS=$'\t' read -r pid acct started; do
      [[ -n "$pid" && -n "$acct" ]] || continue
      rows+=("${pid}"$'\t'"${acct}"$'\t'"${started}")
    done < "$SB_RUNS_FILE"
  fi
  _shared_lock_release

  if (( ${#rows} == 0 )); then
    print "  active shared runs: none"
    return 0
  fi
  print "  active shared runs: ${#rows}"
  local row
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r pid acct started <<< "$row"
    print "    - $(_shared_run_label "$acct") (pid ${pid}, started ${started:-unknown})"
  done
}

_print_recent_tap_warning() {
  [[ -f "${SB_STATE}/traces.jsonl" ]] || return 0
  command -v python3 >/dev/null 2>&1 || return 0
  python3 - "${SB_STATE}/traces.jsonl" <<'PY'
import json, sys
from collections import deque

path = sys.argv[1]
interesting = {"upstream_stream_error", "upstream_closed_before_terminal", "client_aborted"}
try:
    with open(path, "r", encoding="utf-8") as f:
        lines = deque(f, maxlen=200)
except OSError:
    sys.exit(0)

for raw in reversed(lines):
    try:
        trace = json.loads(raw)
    except Exception:
        continue
    if trace.get("route") != "tap":
        continue
    warnings = trace.get("warnings") or []
    hit = next((w for w in warnings if w in interesting), None)
    if not hit:
        continue
    model = trace.get("inbound_model") or "<unknown>"
    status = trace.get("final_status", "?")
    request_id = trace.get("request_id", "?")
    print(f"  recent tap warning: {hit} · model={model} · status={status} · request={request_id}")
    break
PY
}

# Seed the registry once from live homes (copy, never move — non-destructive).
_seed_authreg() {
  mkdir -p "${SB_AUTHREG}/backups" || return 1
  [[ -f "$(_authreg_path default)" ]] || { [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp "${SB_MAIN_HOME}/auth.json" "$(_authreg_path default)"; }
  local a
  for a in ${(f)"$(ls "$CODEX_PROFILES" 2>/dev/null)"}; do
    [[ -f "$(_authreg_path "$a")" ]] || { [[ -f "${CODEX_PROFILES}/$a/auth.json" ]] && cp "${CODEX_PROFILES}/$a/auth.json" "$(_authreg_path "$a")"; }
  done
  [[ -f "$SB_ACTIVE_FILE" ]] || echo default > "$SB_ACTIVE_FILE"
}

_backup_main_auth() {
  [[ -f "${SB_MAIN_HOME}/auth.json" ]] || return 0
  local ts; ts="$(date +%Y%m%d-%H%M%S)"
  cp "${SB_MAIN_HOME}/auth.json" "${SB_AUTHREG}/backups/auth.$(_shared_active).${ts}.json" 2>/dev/null
  # prune to the newest 15 — array glob (never falls back to `ls` of the cwd)
  local -a bk; bk=("${SB_AUTHREG}/backups/"*.json(.Nom))   # om = newest first
  if (( ${#bk} > 15 )); then local f; for f in "${(@)bk[16,-1]}"; do rm -f "$f" 2>/dev/null; done; fi
}

# Make ~/.codex/auth.json hold account $1's credential, capturing any refresh of
# the previously-active account first. Returns 1 if $1 has no stored credential.
_activate_shared() {
  local want="$1" run_pid="${2:-}"
  _shared_lock_acquire || return 1
  _seed_authreg || { _shared_lock_release; return 1; }
  local conflicts; conflicts="$(_shared_conflicts_locked "$want")"
  if [[ -n "$conflicts" ]]; then
    local -a conflict_lines; conflict_lines=("${(@f)conflicts}")
    local first="${conflict_lines[1]}" other_pid other_acct other_started other_label
    IFS=$'\t' read -r other_pid other_acct other_started <<< "$first"
    other_label="$(_shared_run_label "$other_acct")"
    print -P "%F{red}Shared Codex pool is already active as '${other_label}' (pid ${other_pid}).%f" >&2
    if [[ "$other_acct" == __exclusive:* ]]; then
      print -P "Wait for that operation to finish, then retry." >&2
    else
      print -P "Use %F{cyan}--sessions separated%f for '${want}', or wait for that run to finish." >&2
    fi
    _shared_lock_release
    return 1
  fi
  local reg; reg="$(_authreg_path "$want")"
  if [[ ! -f "$reg" ]]; then
    print -P "%F{yellow}No stored credential for '${want}'.%f  Log in:  sb login codex --account ${want}" >&2
    _shared_lock_release
    return 1
  fi
  local cur; cur="$(_shared_active)"
  # persist any token refresh from the currently-live auth back to its slot
  [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp -f "${SB_MAIN_HOME}/auth.json" "$(_authreg_path "$cur")" 2>/dev/null
  if [[ "$want" != "$cur" || ! -f "${SB_MAIN_HOME}/auth.json" ]]; then
    _backup_main_auth
    cp -f "$reg" "${SB_MAIN_HOME}/auth.json" || { print -P "%F{red}auth swap failed%f" >&2; _shared_lock_release; return 1; }
  fi
  echo "$want" > "$SB_ACTIVE_FILE"
  [[ -n "$run_pid" ]] && _shared_register_run_locked "$want" "$run_pid"
  _shared_lock_release
}

# After a shared-mode session: persist refresh back to the account's registry slot.
_saveback_shared() { [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp -f "${SB_MAIN_HOME}/auth.json" "$(_authreg_path "$1")" 2>/dev/null; }

_finish_shared_run() {
  local acct="$1" pid="${2:-$$}"
  _shared_lock_acquire || { _saveback_shared "$acct"; return 0; }
  [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp -f "${SB_MAIN_HOME}/auth.json" "$(_authreg_path "$acct")" 2>/dev/null
  _shared_unregister_run_locked "$pid"
  _shared_lock_release
}

_set_env() {  # persist export KEY="VALUE" into sb.env
  local key="$1" val="$2"; mkdir -p "${SB_ENV:h}"; touch "$SB_ENV"
  if grep -q "^export ${key}=" "$SB_ENV" 2>/dev/null; then
    local tmp; tmp="$(mktemp)"; grep -v "^export ${key}=" "$SB_ENV" > "$tmp"; mv "$tmp" "$SB_ENV"
  fi
  echo "export ${key}=\"${val}\"" >> "$SB_ENV"
}

# fzf menu: stdin "key<TAB>label" → prints chosen key (empty on Esc).
_menu() {
  local prompt="${1:-› }" header="${2:-}"
  if [[ -n "$FZF" ]]; then
    "$FZF" --ansi --reverse --height='~70%' --prompt="$prompt" \
           ${header:+--header="$header"} --delimiter=$'\t' --with-nth=2.. --no-multi --no-info 2>/dev/null | cut -f1
  else
    local -a keys labels; local k l
    while IFS=$'\t' read -r k l; do keys+=("$k"); labels+=("$l"); done
    print -ru2 -- "$header"; local i=1
    for l in "${labels[@]}"; do print -ru2 -- "  $i) $l"; ((i++)); done
    print -nu2 -- "$prompt"; local n; read -r n; [[ "$n" == <-> ]] && echo "${keys[$n]}"
  fi
}

_mark() { [[ "$1" == "$2" ]] && echo "  ◀ default"; }  # _mark <value> <default>

# ─────────────────────────── launch ───────────────────────────

_codex_wrapper() { case "$1" in
  tap) echo "$TAP_WRAPPER" ;; relay) echo "$RELAY_WRAPPER" ;;
  free) echo "$FREE_WRAPPER" ;; native) echo "$NATIVE_CODEX" ;; *) return 1 ;;
esac }

_codex_effective_session_mode() {
  local acct="$1"
  if [[ -n "${sessmode:-}" ]]; then
    print -r -- "$sessmode"
  elif [[ "$SB_SESSION_MODE" == shared && "$acct" != default ]]; then
    print -r -- separated
  else
    print -r -- "$SB_SESSION_MODE"
  fi
}

_codex_session_mode_is_auto_separated() {
  [[ -z "${sessmode:-}" && "$SB_SESSION_MODE" == shared && "$1" != default ]]
}

_run_codex() {  # _run_codex <mode> <account> [args...]
  local m="$1" acct="$2"; shift 2
  _codex_require_account_name "$acct" || return 1
  local wrapper; wrapper="$(_codex_wrapper "$m")" || { print "unknown codex mode: $m"; return 1; }
  local sm; sm="$(_codex_effective_session_mode "$acct")"

  if [[ "$sm" == shared ]]; then
    # All accounts share the ~/.codex session pool; swap the credential in.
    _activate_shared "$acct" "$$" || return 1
    [[ "$m" != native ]] && { _up || print -P "%F{yellow}warning:%f relay :18765 down — 'sb reload'" >&2; }
    print -P "%F{8}(shared sessions · ~/.codex pool · account: ${acct})%f" >&2
    # NOT exec — we must save the refreshed token back afterwards.
    CODEX_HOME="$SB_MAIN_HOME" "$wrapper" "$@"
    local rc=$?
    _finish_shared_run "$acct" "$$"
    return $rc
  fi

  # separated: each account is its own CODEX_HOME (own auth + own sessions).
  local chome; chome="$(_codex_home "$acct")"
  if [[ "$m" == tap || "$m" == native ]] && [[ ! -f "${chome}/auth.json" ]]; then
    print -P "%F{yellow}Account '${acct}' isn't logged in.%f  →  sb login codex --account ${acct}"; return 1
  fi
  [[ "$m" != native ]] && { _up || print -P "%F{yellow}warning:%f relay :18765 down — 'sb reload'" >&2; }
  _codex_session_mode_is_auto_separated "$acct" && print -P "%F{8}(auto-separated sessions · account: ${acct} · CODEX_HOME=${chome})%f" >&2
  CODEX_HOME="$chome" exec "$wrapper" "$@"
}

_valid_profile_name() {
  local name="$1"
  [[ -n "$name" ]] || return 1
  [[ "$name" != "." && "$name" != ".." ]] || return 1
  [[ "$name" != *"/"* && "$name" != *":"* ]] || return 1
  [[ "$name" =~ '^[A-Za-z0-9][A-Za-z0-9._-]*$' ]]
}

_codex_require_account_name() {
  _valid_profile_name "$1" && return 0
  print -P "%F{red}invalid Codex account name%f: '$1' (use letters, numbers, dot, underscore, or dash; no paths)" >&2
  return 1
}

_claude_history_mode() { [[ "$1" == "default" ]] && echo native || echo separate; }

_claude_latest_transcript_for_account() {
  local acct="$1" chome; chome="$(_claude_home "$acct")"
  local -a files
  files=("${chome}/projects"/**/*.jsonl(.Nom))
  (( ${#files} )) && print -r -- "${files[1]}"
}

_claude_latest_transcript() {
  local best_acct="" best_transcript="" acct transcript_path
  for acct in ${(f)"$(_claude_accounts_list)"}; do
    _valid_profile_name "$acct" || continue
    transcript_path="$(_claude_latest_transcript_for_account "$acct")"
    [[ -n "$transcript_path" ]] || continue
    if [[ -z "$best_transcript" || "$transcript_path" -nt "$best_transcript" ]]; then
      best_acct="$acct"
      best_transcript="$transcript_path"
    fi
  done
  [[ -n "$best_transcript" ]] && print -r -- "${best_acct}"$'\t'"${best_transcript}"
}

sb_watch_claude() {
  local acct="" transcript_path="" row="" rest=()
  while (( $# )); do
    case "$1" in
      --account) acct="${2:-}"; shift 2 ;;
      --account=*) acct="${1#--account=}"; shift ;;
      -h|--help)
        print "usage: sb watch claude [--account NAME]"
        return 0 ;;
      *) rest+=("$1"); shift ;;
    esac
  done
  if (( ${#rest} )); then
    print "unknown sb watch claude option: ${rest[1]}" >&2
    return 1
  fi

  if [[ -n "$acct" ]]; then
    _claude_require_account_name "$acct" || return 1
    transcript_path="$(_claude_latest_transcript_for_account "$acct")"
  else
    row="$(_claude_latest_transcript)"
    if [[ -n "$row" ]]; then
      acct="${row%%$'\t'*}"
      transcript_path="${row#*$'\t'}"
    fi
  fi

  if [[ -z "$transcript_path" ]]; then
    [[ -n "$acct" ]] && print "no Claude transcript yet for account '${acct}'" || print "no Claude transcript yet"
    return 1
  fi

  print "Tailing Claude transcript: account=${acct} path=${transcript_path}"
  exec tail -f "$transcript_path"
}

_claude_path_kind() {
  local target_path="$1"
  if [[ -L "$target_path" ]]; then
    echo "link -> $(readlink "$target_path")"
  elif [[ -e "$target_path" ]]; then
    echo "present"
  else
    echo "missing"
  fi
}

_claude_require_account_name() {
  local acct="$1"
  _valid_profile_name "$acct" || { print -P "%F{red}invalid Claude account name:%f ${acct}" >&2; return 1; }
}

_claude_link_path() {
  local src="$1" dst="$2" label="$3"
  [[ -e "$src" ]] || { print -P "%F{red}${label} source does not exist:%f ${src}" >&2; return 1; }
  if [[ -L "$dst" && "$(readlink "$dst")" == "$src" ]]; then
    return 0
  fi
  if [[ -e "$dst" || -L "$dst" ]]; then
    print -P "%F{yellow}${label} already exists, keeping:%f ${dst}" >&2
    return 0
  fi
  ln -s "$src" "$dst"
}

_claude_memory_note() {
  local acct="$1" dest="$2"
  cat > "$dest" <<EOF
# Claude profile: ${acct}

This is a Switchback-managed native Claude Code profile.
It keeps user-level Claude memory and local transcripts separate from ~/.claude.

Project-level CLAUDE.md files are still discovered by native Claude Code from the repo.
EOF
}

sb_claude_init() {  # sb_claude_init <account> [--copy-user-memory|--link-user-memory] [--link-agents]
  local acct="${1:-$SB_DEFAULT_CLAUDE_ACCOUNT}"; shift 2>/dev/null || true
  _claude_require_account_name "$acct" || return 1

  local copy_memory=0 link_memory=0 link_agents=0
  while (( $# )); do
    case "$1" in
      --copy-user-memory) copy_memory=1; shift ;;
      --link-user-memory) link_memory=1; shift ;;
      --link-agents) link_agents=1; shift ;;
      -h|--help)
        print "usage: sb claude init --account NAME [--copy-user-memory|--link-user-memory] [--link-agents]"
        return 0 ;;
      *) print "unknown claude init option: $1" >&2; return 1 ;;
    esac
  done
  if (( copy_memory && link_memory )); then
    print "choose only one of --copy-user-memory or --link-user-memory" >&2
    return 1
  fi

  local home; home="$(_claude_home "$acct")"
  mkdir -p "$home" "${home}/projects" "${home}/commands" "${home}/hooks" || return 1

  local global_memory="${HOME}/.claude/CLAUDE.md"
  local profile_memory="${home}/CLAUDE.md"
  if (( link_memory )); then
    _claude_link_path "$global_memory" "$profile_memory" "CLAUDE.md" || return 1
  elif (( copy_memory )) && [[ -f "$global_memory" && ! -e "$profile_memory" && ! -L "$profile_memory" ]]; then
    cp "$global_memory" "$profile_memory"
  elif [[ ! -e "$profile_memory" && ! -L "$profile_memory" ]]; then
    _claude_memory_note "$acct" "$profile_memory"
  fi

  local global_agents="${HOME}/.claude/agents"
  local profile_agents="${home}/agents"
  if (( link_agents )); then
    _claude_link_path "$global_agents" "$profile_agents" "agents" || return 1
  else
    mkdir -p "$profile_agents" || return 1
  fi

  print "Claude profile ready:"
  print "  account: ${acct}"
  print "  config: ${home}"
  print "  history: $(_claude_history_mode "$acct")"
  print "  memory: $(_claude_path_kind "$profile_memory")"
  print "  agents: $(_claude_path_kind "$profile_agents")"
  print "Run it: sb claude --account ${acct}"
}

sb_claude_accounts() {
  print "Claude accounts (native profiles):"
  local acct
  for acct in ${(f)"$(_claude_accounts_list)"}; do
    _valid_profile_name "$acct" || continue
    local home; home="$(_claude_home "$acct")"
    local n; n=$(find "${home}/projects" -name '*.jsonl' 2>/dev/null | wc -l | tr -d ' ')
    local marker="profile"
    [[ "$acct" == "$SB_DEFAULT_CLAUDE_ACCOUNT" ]] && marker="${marker}, default"
    [[ "$acct" == "default" ]] && marker="${marker}, native"
    print "  ${acct}  -> ${home}  (${marker}, history=$(_claude_history_mode "$acct"), ${n} transcripts)"
  done
  print "Add one: sb claude init --account <name> [--copy-user-memory|--link-user-memory] [--link-agents]"
}

