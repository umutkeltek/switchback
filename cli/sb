    case "${1:-}" in
      native) shift; sb_verify_native "$@" ;;
      ""|-h|--help) print "usage: sb verify native [--exercise large-payload|stream|websocket]" ;;
      *) print "unknown verify target: $1"; exit 1 ;;
    esac ;;
  usage)          sb_usage ;;
  traces)         sb_recent_traces ;;
  sessions)       sb_sessions "$@" ;;
  reload)         sb_reload; sb_status ;;

  codex)    _take_opts "$@"; _run_codex "${mode:-$SB_DEFAULT_CODEX_MODE}" "$account" "${REST[@]}" ;;
  claude)   sb_claude "$@" ;;
  opencode) sb_opencode "$@" ;;
  pi)       sb_pi "$@" ;;

  login)    sub="${1:-codex}"; [[ "$sub" == "codex" ]] && shift
            _take_opts "$@"; sb_login "$account" ;;

  accounts)
    print "Codex accounts (ChatGPT profiles):"
    for a in ${(f)"$(_accounts_list)"}; do
      chome="$(_codex_home "$a")"
      n=$(find "${chome}/sessions" -name '*.jsonl' 2>/dev/null | wc -l | tr -d ' ')
      print "  ${a}  -> ${chome}  $([[ -f ${chome}/auth.json ]] && echo "(logged in, ${n} sessions)" || echo '(no auth)')"
    done
    print "Add one:  sb login codex --account <name>   ·   menu:  sb → Accounts"
    print ""
    sb_claude_accounts ;;

  settings) _menu_settings ;;
  observe)  _menu_observe ;;
  native)   _switchback native --config "$SB_CONFIG" "$@" ;;
  profiles) _switchback native profiles --config "$SB_CONFIG" "$@" ;;
  config)
    case "${1:-}" in
      ""|-h|--help) _switchback config --help ;;
      *) _switchback config "$@" --config "$SB_CONFIG" ;;
    esac ;;

  watch)
    target="${1:-codex}"
    [[ $# -gt 0 ]] && shift
    if [[ "$target" == claude ]]; then
      sb_watch_claude "$@"
      exit $?
    fi
    touch "${SB_STATE}/traces.jsonl" "${SB_STATE}/tap-bodies.jsonl" 2>/dev/null
    print "Tailing traces + bodies (Ctrl-C to stop)…  (Claude: sb watch claude)"
    exec tail -f "${SB_STATE}/traces.jsonl" "${SB_STATE}/tap-bodies.jsonl" ;;

  capture)
    case "${1:-}" in
      on|off) nv=$([[ "$1" == on ]] && echo true || echo false)
        sed -i '' "s/capture_bodies: .*/capture_bodies: ${nv}/g" "$SB_CONFIG" 2>/dev/null
        print "capture_bodies → ${nv}; reloading…"; sb_reload ;;
      *) grep -m1 capture_bodies "$SB_CONFIG" 2>/dev/null | sed 's/^ *//' || echo "no tap configured" ;;
    esac ;;

  modes)
    cat <<EOF
Modes (default per tool in (), change via 'sb settings'):
  codex   tap (${SB_DEFAULT_CODEX_MODE})  native request, observed       · very low risk
          relay                           Mode C canonical routing/usage · native_auth_reissued
          native                          untouched escape hatch         · native_direct_unobserved
          free                            scout pool                     · api_compatible_scout
  claude  native (${SB_DEFAULT_CLAUDE_MODE})  subscription, observed via hooks (no proxy — ToS)
          free                            scout pool
  opencode  gateway   via :18765, observed (replaces dead OmniRoute)
  pi        gateway   via :18765, observed (~/.pi/agent/models.json)

  Claude account default: ${SB_DEFAULT_CLAUDE_ACCOUNT} (profiles in ${CLAUDE_PROFILES}; default = ~/.claude)

  Sessions: shared (default; native-Codex one ~/.codex pool) | separated (isolated).
            sb sessions [status|reset|shared|separated]   ·   per run: --sessions M

  sb codex [--mode tap|relay|native|free] [--account NAME] [--sessions separated|shared] [args]
  sb claude [--mode native|free] [--account NAME] [args]
  sb claude accounts | init --account NAME | doctor --account NAME
  sb               interactive menu (arrows · Enter · Esc)
EOF
    ;;

  help|-h|--help|*)
    cat <<'EOF'
sb — Switchback control

  sb                         interactive menu (Run · Accounts · Settings · Observe · Relay)
  sb status | usage | traces snapshot of what's flowing
  sb doctor                  check the setup is ready (relay, taps, tools, catalog)
  sb verify native           strict native Codex/Claude fidelity preflight
  sb verify native --exercise large-payload --exercise stream --exercise websocket
  sb modes                   modes + current defaults

  sb codex  [--mode M] [--account X] [args]   M = tap | relay | native | free
  sb claude [--mode M] [--account X] [args]   M = native | free
  sb claude accounts         list native Claude profiles
  sb claude init --account X create a native Claude profile
  sb claude doctor --account X explain config/history/memory for a profile
  sb opencode [args]         OpenCode via the gateway (observed)
  sb pi [args]               pi via the gateway (observed)

  sb sessions [status|reset]  separated vs shared session pool across accounts
  sb login codex --account X log in a ChatGPT account into its own profile
  sb accounts                list Codex accounts + Claude profiles
  sb settings                defaults: modes · Codex/Claude accounts · model · effort · capture
  sb native status           native Codex/Claude readiness + fidelity
  sb profiles list|env NAME  native profile readiness + env hints
  sb config get/set/...      live config edits against ~/.config/switchback/switchback.yaml
  sb observe                 status · traces · usage · watch
  sb watch [claude]          live-tail traffic; Claude auto-detects newest profile transcript
  sb watch claude --account X live-tail one Claude profile
  sb reload                  full relay reload

Smart defaults: `sb codex` / `sb claude` run your default mode; the menu lets you switch per run.
Codex accounts and Claude profiles are manual selections. No automatic account rotation.
EOF
    ;;
esac
