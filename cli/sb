sb_sessions() {
  case "${1:-status}" in
    status|"")
      print -P "%F{cyan}Session mode%f: ${SB_SESSION_MODE}"
      print "  separated = each account its own sessions · shared = all use the ~/.codex pool"
      if [[ "$SB_SESSION_MODE" == shared || -d "$SB_AUTHREG" ]]; then
        print "  live credential in ~/.codex: $(_shared_active)"
        print "  registry: ${SB_AUTHREG}"
        local f; for f in "${SB_AUTHREG}"/*.json(.N); do print "    - ${f:t:r}"; done
        local -a bk; bk=("${SB_AUTHREG}/backups/"*.json(.N)); print "  backups:  ${#bk} kept"
      fi ;;
    reset)
      [[ "$SB_SESSION_MODE" == shared ]] || { print "reset only applies in shared mode"; return 0; }
      _activate_shared default && print -P "%F{green}~/.codex restored to the default account.%f" ;;
    shared|separated)
      _set_env SB_SESSION_MODE "$1"; SB_SESSION_MODE="$1"; print "session mode → $1"
      [[ "$1" == shared ]] && _seed_authreg ;;
    *) print "usage: sb sessions [status|reset|shared|separated]" ;;
  esac
}

sb_login() {
  local account="${1:-default}" chome; chome="$(_codex_home "$account")"; mkdir -p "$chome"
  if [[ "$SB_SESSION_MODE" == shared ]]; then   # capture the live slot's owner before any change
    _seed_authreg
    [[ -f "${SB_MAIN_HOME}/auth.json" ]] && cp -f "${SB_MAIN_HOME}/auth.json" "$(_authreg_path "$(_shared_active)")" 2>/dev/null
  fi
  print -P "Logging in ChatGPT account %F{cyan}${account}%f (CODEX_HOME=${chome}). A browser will open."
  CODEX_HOME="$chome" command codex login
  if [[ "$SB_SESSION_MODE" == shared ]]; then   # keep the registry in sync with the fresh credential
    _seed_authreg
    [[ -f "${chome}/auth.json" ]] && cp -f "${chome}/auth.json" "$(_authreg_path "$account")" 2>/dev/null
    [[ "$account" == default ]] && echo default > "$SB_ACTIVE_FILE"   # ~/.codex now holds default
  fi
  print -P "%F{green}Done.%f  Run it:  sb codex --account ${account}"
}

