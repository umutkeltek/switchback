_pick_session() {  # echoes: "" | "resume --last" | "resume --all --include-non-interactive" | ...
  # Codex hides sessions TWO ways: by folder (--all) and by excluding
  # non-interactive/exec sessions (--include-non-interactive). "Everything"
  # passes both so nothing is hidden; the folder options stay scoped.
  local s; s=$(printf '%s\n' \
    $'new\t🆕 New session' \
    $'last\t⏭  Resume the most recent session' \
    $'all\t📂 Resume… EVERYTHING (any folder, incl. automation)' \
    $'allint\t📂 Resume… all folders (interactive only)' \
    $'here\t📁 Resume… only this folder' \
    | _menu "session › " "Codex hides by folder AND by non-interactive — EVERYTHING shows all")
  case "$s" in
    last)   echo "resume --last" ;;
    all)    echo "resume --all --include-non-interactive" ;;
    allint) echo "resume --all" ;;
    here)   echo "resume --include-non-interactive" ;;
    new)    echo "" ;;
    *)      echo "ABORT" ;;
  esac
}

