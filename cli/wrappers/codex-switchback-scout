#!/bin/zsh
set -euo pipefail

export SWITCHBACK_SCOUT_API_KEY="${SWITCHBACK_SCOUT_API_KEY:-scout-local}"

config_overrides=(
  -c 'model_provider="switchback-scout"'
  -c 'model="scout/code"'
  -c 'model_reasoning_effort="low"'
  -c 'model_providers.switchback-scout={name="Switchback Scout", base_url="http://127.0.0.1:18765/v1", wire_api="responses", env_key="SWITCHBACK_SCOUT_API_KEY", requires_openai_auth=false}'
)

case "${1:-}" in
  doctor)
    shift
    exec codex "${config_overrides[@]}" doctor "$@"
    ;;
  *)
    exec codex -p switchback-scout "$@"
    ;;
esac
