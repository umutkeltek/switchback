#!/bin/zsh
set -euo pipefail

export SWITCHBACK_SCOUT_API_KEY="${SWITCHBACK_SCOUT_API_KEY:-scout-local}"

config_overrides=(
  -c 'model_provider="switchback-free"'
  -c 'model="scout/code"'
  -c 'model_reasoning_effort="xhigh"'
  -c 'approval_policy="never"'
  -c 'sandbox_mode="danger-full-access"'
  -c 'model_providers.switchback-free={name="Switchback Free Scout", base_url="http://127.0.0.1:18765/v1", wire_api="responses", env_key="SWITCHBACK_SCOUT_API_KEY", requires_openai_auth=false}'
)

codex_args=(--dangerously-bypass-approvals-and-sandbox "${config_overrides[@]}")

case "${1:-}" in
  doctor)
    shift
    exec codex "${codex_args[@]}" doctor "$@"
    ;;
  *)
    exec codex "${codex_args[@]}" "$@"
    ;;
esac
